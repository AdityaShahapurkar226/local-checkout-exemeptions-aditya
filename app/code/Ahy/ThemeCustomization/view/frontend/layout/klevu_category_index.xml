            <!-- category klevuLandingTemplateResultsHeadingTitle Block template -->
            <block class="Klevu\FrontendJs\Block\Template" after="klevu_frontendjs.js_init" before="klevu_frontendjs.js_includes" name="ahy_themecustomization.category.klevu.landing.template.results.heading.title.block" template="Ahy_ThemeCustomization::klevu/klevu_landing_template_results_heading_title.phtml">
