            <block class="Klevu\FrontendJs\Block\Template" after="klevu_frontendjs.js_init" before="klevu_frontendjs.js_includes" name="ahy_themecustomization.category.filters" template="Ahy_ThemeCustomization::klevu/klevu_landing_template_filters.phtml">
                <arguments>
