                    </argument>
                </arguments>
            </block>

            <!-- category landing page product card add to cart Block template -->
            <block class="Klevu\FrontendJs\Block\Template" after="klevu_frontendjs.js_init" before="klevu_frontendjs.js_includes" name="ahy_themecustomization.category.landing.template.product.card.block" template="Ahy_ThemeCustomization::klevu/landing_page_product_addToCart.phtml">
                <arguments>
                    <!--
                        We will use the existing condition from the Klevu_Categorynavigation module to ensure
                        that our changes to the frontend search options only take place when the
                        relevant configuration is enabled
                    -->
                    <argument name="is_enabled_conditions_fqcn" xsi:type="array">
                        <item name="klevu_catnav_themev2" xsi:type="string">Klevu\Categorynavigation\Service\ThemeV2\IsEnabledCondition</item>
                    </argument>
                </arguments>
            </block>

            <!-- category klevu Landing Template Results Block template -->
            <block class="Klevu\FrontendJs\Block\Template" after="klevu_frontendjs.js_init" before="klevu_frontendjs.js_includes" name="ahy_themecustomization.category.klevu.landing.template.results.block" template="Ahy_ThemeCustomization::klevu/klevu_landing_template_results.phtml">
