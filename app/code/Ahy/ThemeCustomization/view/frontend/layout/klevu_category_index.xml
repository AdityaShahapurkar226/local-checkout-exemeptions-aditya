                    </argument>
                </arguments>
            </block>

            <!-- category kuFilterTagsTemplate Block template -->
            <block class="Klevu\FrontendJs\Block\Template" after="klevu_frontendjs.js_init" before="klevu_frontendjs.js_includes" name="ahy_themecustomization.category.ku.filter.tags.template.block" template="Ahy_ThemeCustomization::klevu/ku_filter_tags_template.phtml">
                <arguments>
                    <!--
                        We will use the existing condition from the Klevu_Categorynavigation module to ensure
                        that our changes to the frontend search options only take place when the
                        relevant configuration is enabled
                    -->
                    <argument name="is_enabled_conditions_fqcn" xsi:type="array">
