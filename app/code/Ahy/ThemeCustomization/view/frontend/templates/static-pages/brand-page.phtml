<section class="container" x-data="searchBrand()">
	<div class="search-bar md:w-1/2 lg:w-1/3 m-auto py-4 relative space-y-4" @click.outside="closeSearch">
		<input
			id="search-brand"
			type="text"
			autocomplete="off"
			name="product-brand"
			value=""
			placeholder="Search For Brands..."
			maxlength="128"
			x-model="search"
			@input="getItems"
			class="w-full p-2 py-3 leading-normal placeholder-black transition appearance-none text-grey-800 focus:outline-transparent focus:border-black focus:ring-black pl-6 rounded-full border-transparent"
		/>
		<div class="absolute inset-y-0 right-0 pr-6 flex items-center !m-0">
			<!-- focus on the search bar -->
			<button
				id="menu-search-icon"
				class="inline-block no-underline hover:text-black"
				@click.prevent="
                    searchOpen = !searchOpen;
                    $nextTick(() => {
                    const searchInput = document.getElementById('search-brand');
                    searchInput.focus();
                    searchInput.select();
                });"
				x-show="!isSearchEmpty"
			>
				<span class="sr-only label"> Search </span>
				<span class="pr-2 pl-3 bg-[url('/media/icons/mag-icon.svg')] bg-contain bg-no-repeat bg-center"></span>
			</button>

			<!-- clear the search bar -->
			<button @click="cleanSearch" aria-label="Close panel" class="text-ahy-blue transition duration-150 ease-in-out hover:text-black" x-show="isSearchEmpty" style="display: none">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"></path>
				</svg>
			</button>
		</div>
		<div role="list" :open="isOpen" x-show="isOpen" style="display: none" class="absolute z-50 w-full transition duration-300 overflow-y-auto max-h-[300px] px-4 ahy-swipeable">
			<ul role="listbox" class="space-y-2 bg-white p-4">
				<template x-for="item in getItems" :key="item">
					<li class="px-4">
						<template x-if="item !== 'No results found'">
							<a
								:href="`https://www.everest.com/search/?q=${encodeURIComponent(item)}&productListFilters=product_brand%3A${encodeURIComponent(item)}`"
								class="group transition-all duration-300 ease-in-out cursor-pointer"
							>
								<span
									class="bg-left-bottom bg-gradient-to-r from-black to-black bg-[length:0%_2px] bg-no-repeat group-hover:bg-[length:100%_2px] transition-all duration-500 ease-out"
									x-text="item"
								></span>
							</a>
						</template>
						<template x-if="item === 'No results found'">
							<span class="cursor-not-allowed opacity-50" x-text="item"></span>
						</template>
					</li>
				</template>
			</ul>
		</div>
	</div>

