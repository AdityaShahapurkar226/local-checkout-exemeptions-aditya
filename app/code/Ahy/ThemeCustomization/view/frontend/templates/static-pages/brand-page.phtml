		<div class="sr-only">goto top</div>
		<svg xmlns="http://www.w3.org/2000/svg" fill="none" title="goto top" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
			<path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
		</svg>
