<script>
	// Show/hide the scroll-to-top button based on scroll position
	window.onscroll = function () {
		scrollFunction();
	};

	function scrollFunction() {
		const scrollToTopBtn = document.getElementById("scrollToTopBtn");
		if (document.body.scrollTop > 250 || document.documentElement.scrollTop > 250) {
			scrollToTopBtn.classList.remove("hidden");
		} else {
			scrollToTopBtn.classList.add("hidden");
		}
	}

	// Scroll to the top when the button is clicked
	function scrollToTop() {
		// For modern browsers that support smooth scrolling
		if ("scrollBehavior" in document.documentElement.style) {
			window.scrollTo({
				top: 0,
				behavior: "smooth",
			});
		} else {
			// For browsers that do not support smooth scrolling, use the previous method
			document.body.scrollTop = 0; // For Safari
			document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE, and Opera
		}
	}

	document.addEventListener("alpine:init", () => {
		Alpine.data("searchBrand", () => ({
			isOpen: false,
			searchOpen: false,
			search: "",
			isSearchEmpty: false,
			sourceData: [],
			categorizedBrandData: {},
			baseurl: window.location.origin,
			get getItems() {
				const filterItems = this.sourceData
					.filter(item => {
						// return item.toLowerCase().startsWith(this.search.toLowerCase());
						return item.toLowerCase().includes(this.search.toLowerCase());
					})
					.sort((a, b) => a.localeCompare(b));

				this.isSearchEmpty = this.search.length > 0;
				if (filterItems.length < this.sourceData.length && filterItems.length > 0) {
					this.isOpen = true;
					return filterItems;
				} else {
					if (this.isSearchEmpty) {
						this.isOpen = true;
						// Return a special value or indication for no results found
						return ["No results found"];
					}
					this.isOpen = false;
				}
			},

			init() {
				var myHeaders = new Headers();
				myHeaders.append("Content-Type", "application/json");
				let apiKeys = ["klevu-168266850400116098"];
    			let klevuUrl = "https://uscs32v2.ksearchnet.com/cs/v2/search";
				if (this.baseurl === "https://staging.everest.com") {
					apiKeys = ["klevu-170582282221816098"];  // Update API key
					klevuUrl = "https://uscs33v2.ksearchnet.com/cs/v2/search";  // Update URL
				}

				var raw = JSON.stringify({
					context: {
						apiKeys: apiKeys,
					},
					recordQueries: [
						{
							id: "productList",
							typeOfRequest: "SEARCH",
							settings: {
								query: {
									term: "*",
								},
								typeOfRecords: ["KLEVU_PRODUCT"],
								limit: 100000,
								fields: ["id", "product_brand"],
								searchPrefs: ["searchCompoundsAsAndQuery"],
							},
						},
					],
				});

				var requestOptions = {
					method: "POST",
					headers: myHeaders,
					body: raw,
					redirect: "follow",
				};

				fetch(klevuUrl, requestOptions)
					.then(response => response.text())
					.then(result => {
						// Encode the entire result to then decode it
						var decodedResult = JSON.parse(result);
						// Assuming decodedResult is the decoded JSON object
						var records = decodedResult.queryResults[0].records;

						// Extract product brands from the records array, handling cases where product_brand is not defined
						var productBrands = records.filter(record => record.product_brand !== undefined).map(record => record.product_brand.replace(/^'|'$/g, "").trim());

						// Filter unique product brands
						var uniqueProductBrands = [...new Set(productBrands)];

						this.sourceData = uniqueProductBrands.sort((a, b) => a.localeCompare(b));
						// Call categorizeBrandNames after setting the sourceData
						this.categorizeBrandNames();
						// Log the unique product brands array
						// console.log("Unique Product Brands:", this.sourceData);

						var brandEl = document.getElementById("brand-sections-skeletal-loading");
						console.log("brandEl:", brandEl); // Check if brandEl is correctly identified
						if (brandEl) {
							console.log("Removing brandEl");
							brandEl.remove();
						}
					})
					.catch(error => console.log("error", error));
			},

			cleanSearch(e) {
				this.search = "";
			},
			closeSearch() {
				this.search = "";
				this.isOpen = false;
			},

			scrollToConservation(event) {
				var clickedEl = event.target.innerText.toUpperCase();
				const conservationEl = document.getElementById(clickedEl);
				if (conservationEl) {
					conservationEl.scrollIntoView({
						behavior: "smooth",
					});
				} else {
					alert(`No brands are available under ${clickedEl}.`);
				}
			},

			categorizeBrandNames() {
				this.sourceData.forEach(name => {
					const category = this.getBrandCategory(name);

					if (!this.categorizedBrandData[category]) {
						this.categorizedBrandData[category] = [];
					}

					this.categorizedBrandData[category].push(name);
				});
			},

			getBrandCategory(name) {
				// Remove non-printable characters including Left-to-Right Mark
				const cleanedName = name.replace(/[\p{C}]/gu, "");
				// Get the first letter of the cleaned name
				const firstLetter = cleanedName.charAt(0).toUpperCase();

				switch (true) {
					case firstLetter >= "0" && firstLetter <= "9":
						return "0-9";
					case firstLetter >= "A" && firstLetter <= "B":
						return "A-B";
					case firstLetter === "C":
						return "C";
					case firstLetter >= "D" && firstLetter <= "E":
						return "D-E";
					case firstLetter >= "F" && firstLetter <= "G":
						return "F-G";
					case firstLetter >= "H" && firstLetter <= "J":
						return "H-J";
					case firstLetter >= "K" && firstLetter <= "L":
						return "K-L";
					case firstLetter >= "M" && firstLetter <= "N":
						return "M-N";
					case firstLetter >= "O" && firstLetter <= "Q":
						return "O-Q";
					case firstLetter >= "R" && firstLetter <= "S":
						return "R-S";
					case firstLetter === "T":
						return "T";
					case firstLetter >= "U" && firstLetter <= "Z":
						return "U-Z";
					default:
						return "Other";
				}
			},
		}));
	});
</script>
