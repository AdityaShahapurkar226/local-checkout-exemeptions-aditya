<script>
	function initializeSwiper() {
		const swiper = new Swiper(".celebrity-slider", {
			// Optional parameters
			direction: "horizontal",
			loop: false,
			// If we need pagination
			pagination: {
				el: ".swiper-pagination",
				clickable: true,
			},
			allowTouchMove: true,
			noSwiping: false,
			mousewheel: {
				forceToAxis: true,
			},

			autoplay: {
				delay: 3000,
				pauseOnMouseEnter: true,
			},
			freeMode: true,
			spaceBetween: 10,
			grabCursor: true,
			// Responsive breakpoints
			breakpoints: {
				// when window width is >= 320px
				0: {
					slidesPerView: 2,
				},
				// when window width is >= 640px
				480: {
					slidesPerView: 3,
				},
				// when window width is >= 1024
				1024: {
					slidesPerView: 5,
				},
				// when window width is >= 1280
				1280: {
					slidesPerView: 6,
				},
			},
		});
	}

	function checkAndInitialize() {
		const elementsExist = document.querySelectorAll(".celebrity-slider").length > 0;
		console.log("🚀 ~ checkAndInitialize ~ elementsExist:", elementsExist);
		if (elementsExist) {
			initializeSwiper();
			setTimeout(() => {
				clearInterval(interval);
			}, 2000); // 2000 milliseconds = 2 seconds
		}
		const sliderEl = document.getElementsByClassName("celebrity-slider")[0];
		if (sliderEl) {
			sliderEl.classList.remove("opacity-0");
		}
	}

	// Check every second
	const interval = setInterval(checkAndInitialize, 1000);
</script>
<style>
	.celebrity-slider img {
		aspect-ratio: 1;
		object-fit: contain;
	}

	/* For elements with overflow that should still allow scrolling but hide the scrollbar */
	.hide-scrollbar-scrollable {
		overflow: auto;
		scrollbar-width: none;/* Firefox */
	}

	.hide-scrollbar-scrollable::-webkit-scrollbar,
	.hide-scrollbar-scrollable::-webkit-scrollbar-thumb {
		display: none; /* Chrome, Safari, and newer Edge */
	}
</style>
