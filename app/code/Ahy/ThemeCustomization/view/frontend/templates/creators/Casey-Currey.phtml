<script>
	// Get all elements with the class "capitalize"
	var elements = document.querySelectorAll('.capitalize');

	// Function to capitalize the first letter of each word
	function capitalizeFirstLetter(str) {
		return str.toLowerCase().replace(/(?:^|\s)\S/g, function(a) { return a.toUpperCase(); });
	}

	// Iterate over each element
	elements.forEach(function(element) {
		// Get the text content of the element
		var text = element.textContent || element.innerText;

		// Capitalize the text
		var capitalizedText = capitalizeFirstLetter(text);

		// Set the capitalized text as the new content of the element
		element.textContent = capitalizedText;
	});
</script>
