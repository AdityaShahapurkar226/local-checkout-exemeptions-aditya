<?php

/** @var \Ahy\EfflApiIntegration\Magewire\HyvaCheckout\AhyFflSelection $magewire */
$dealers = array_slice($magewire->dealers, 0, 100);
$dealersJson = htmlspecialchars(json_encode($dealers, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), ENT_QUOTES, 'UTF-8');
?>

<div
    x-data="{
        selectedId: $wire.entangle('selectedFflDealerId'),
        acceptTerms: $wire.entangle('agreeOnTermAndCondition'),
        hasUserSelected: false,
        selectedDealer: null,
        errorMessage: '',
        searchQuery: '',
        allDealers: <?= $dealersJson ?>,
        get filteredDealers() {
            if (!this.searchQuery) return this.allDealers;
            let q = this.searchQuery.toLowerCase();
            return this.allDealers.filter(d =>
                (d.dealer_name && d.dealer_name.toLowerCase().includes(q)) ||
                (d.street && d.street.toLowerCase().includes(q)) ||
                (d.city && d.city.toLowerCase().includes(q)) ||
                (d.state && d.state.toLowerCase().includes(q)) ||
                (d.zip_code && d.zip_code.toLowerCase().includes(q))
            );
        }
    }"
    x-effect="$dispatch('ffl-state-change', { selectedId, acceptTerms, hasUserSelected, selectedDealer })"
    @ffl:selection:error.window="errorMessage = $event.detail.message.text ?? $event.detail.message"
    @ffl:selection:success.window="errorMessage = ''"
    class="relative space-y-4 border p-2 px-4 m-2.5 rounded-xl shadow">

    <!-- Loader Overlay -->
    <div
        wire:loading.class="absolute inset-0 bg-white/70 backdrop-blur-sm flex items-center justify-center rounded-xl z-20 loader"
        wire:target="selectedFflDealer" class="hidden">
        <div class="w-9 h-9">
            <img src="/media/icons/everest-loading-icon.gif" alt="everest loading icon" class="w-full h-full">
        </div>
    </div>

    <!-- Header -->
    <div class="flex items-center justify-between">
        <h3 class="text-ahy-blue text-lg font-semibold">
            Nearby FFL Dealers
        </h3>
    </div>

    <!-- Search bar -->
    <div class="mt-2 relative">
        <input
            type="text"
            x-model="searchQuery"
            :placeholder="window.innerWidth < 640 
             ? 'Search dealers…' 
            : 'Search dealers by name, street, city, state, or zip...'"
            class="w-full border rounded-full pr-10 pl-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        <span class="absolute right-3 top-1/2 transform -translate-y-1/2 bg-[url('/media/icons/mag-icon.svg')] bg-contain bg-no-repeat w-5 h-5"></span>
    </div>


    <!-- Error message -->
    <template x-if="errorMessage">
        <div class="bg-red-100 text-red-700 p-2 rounded">
            <span x-text="errorMessage"></span>
        </div>
    </template>

    <?php if (!empty($dealers)): ?>
        <!-- Displaying first 100 FFL dealers -->
        <?php $dealers = array_slice($magewire->dealers, 0, 100); ?>
        <!-- Scrollable Card grid -->
        <div class="dealer_container overflow-y-auto pr-2 mt-3">
            <ul class="grid grid-cols-1 xl:grid-cols-2 gap-4">
                <template x-for="dealer in filteredDealers" :key="dealer.entity_id">
                    <li
                        class="p-5 border bg-white rounded-xl shadow-sm hover:shadow-md transition-all cursor-pointer m-1 h-45"
                        :class="{ 'ahy-border-blue-600 border-ring ring-blue-300': selectedId == dealer.entity_id }"
                        @click.prevent="hasUserSelected = true; selectedDealer = dealer; $wire.selectedFflDealer(dealer.entity_id)">
                        <div class="flex items-start">
                            <!-- Dealer info -->
                            <div class="w-3/5 pr-2 dealer_info max dealer-info">
                                <p class=" font-medium text-gray-800" x-text="dealer.dealer_name"></p>
                                <p class="text-sm text-gray-600"
                                    x-text="dealer.distance ? Number(dealer.distance).toFixed(2) + ' miles away' : ''"></p>
                                <!-- Dealer address/details inside same column -->
                                <div class="mt-2 text-sm text-gray-700">
                                    <p x-text="dealer.street"></p>
                                    <p x-text="(dealer.city || '') + ', ' + (dealer.state || '') + ' ' + (dealer.zip_code || '')"></p>
                                </div>
                            </div>
                            <!-- Select button -->
                            <div class="w-2/5 flex justify-end items-start dealer_btn">
                                <button
                                    type="button"
                                    class="px-4 py-1 text-sm rounded-md border transition"
                                    :class="selectedId == dealer.entity_id 
                                        ? 'dealer-btn-active' 
                                        : 'dealer-btn-inactive'">
                                    <span x-show="selectedId != dealer.entity_id">Select</span>
                                    <span x-show="selectedId == dealer.entity_id">Selected</span>
                                </button>

                            </div>
                        </div>
                    </li>
                </template>
            </ul>
            <!-- No results -->
            <template x-if="filteredDealers.length === 0">
                <p class="!text-ahy-red mt-0 p-3 text-base italic font-medium pl-0">No FFL dealers found matching your search.</p>
            </template>
        </div>

        <!-- Terms acknowledgement -->
        <div class="flex items-start space-x-2 mt-5">
            <input
                id="ffl-terms"
                type="checkbox"
                x-model="acceptTerms"
                @change="$wire.updateAgreeOnTermAndCondition(acceptTerms)"
                class="mt-1 h-4 w-4 border-gray-300 rounded cursor-pointer">
            <label for="ffl-terms" class="text-sm text-gray-700 tracking-[1px] cursor-pointer w-full">
                I acknowledge and agree that it is solely my responsibility to contact the Federal Firearms Licensee (FFL) I selected during checkout to confirm their willingness and ability to accept the transfer of my firearm(s), including compliance with all applicable federal, state, and local laws, and any additional requirements, fees, or conditions imposed by the FFL. I further acknowledge that <a href="/" class="text-blue-600 hover:underline">Everest.com</a> and its affiliates have no responsibility or liability for the refusal of any FFL to accept a transfer, for delays arising from such refusal, or for any additional costs or obligations imposed by the selected FFL. In the event of any changes to my order, transfer details, or chosen FFL, I am solely responsible for promptly notifying both the receiving FFL, the seller from whom the firearm(s) were purchased, and <a href="/" class="text-blue-600 hover:underline">Everest.com</a>. I understand and agree that failure to comply with these responsibilities may result in delays, additional fees, or cancellation of my order, for which I shall remain fully liable.
            </label>
        </div>
    <?php else: ?>
        <p class="text-gray-600">
            We couldn’t find any FFL dealers near your shipping address.
        </p>
    <?php endif; ?>
</div>
