<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <container name="checkout.ahy.ffl.selection" htmlTag="div" htmlClass="ffl-selection">
            <block name="checkout.ffl.verification"
                   template="Ahy_EfflApiIntegration::checkout/verification/ffl.phtml">
                <arguments>
                    <argument name="magewire" xsi:type="object">
                        \Ahy\EfflApiIntegration\Magewire\HyvaCheckout\AhyFflSelection
                    </argument>
                    <argument name="view_model" xsi:type="object">Ahy\EfflApiIntegration\ViewModel\FflDealers</argument>
                </arguments>
            </block>
        </container>
        <move element="checkout.ahy.ffl.selection" destination="column.main" before="-"/>
    </body>
</page>
