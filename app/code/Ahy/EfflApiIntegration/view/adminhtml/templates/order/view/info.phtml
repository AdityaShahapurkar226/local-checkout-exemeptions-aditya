$order = $block->getOrder();

$baseCurrencyCode = (string)$order->getBaseCurrencyCode();
$globalCurrencyCode = (string)$order->getGlobalCurrencyCode();
$orderCurrencyCode = (string)$order->getOrderCurrencyCode();
$restriction = $order->getOrchidRestrictionLevel();


$orderRestrictionCode = null;
$shippingCode = null;
$ageCode = null;

// Decode order-level restriction JSON
if (is_string($restriction)) {
    $decodedRestriction = json_decode($restriction, true);
    if (json_last_error() === JSON_ERROR_NONE) {
        $orderRestrictionCode = $decodedRestriction['restriction'] ?? null;
        $shippingCode         = $decodedRestriction['shipping_restriction'] ?? null;
        $ageCode              = $decodedRestriction['age_restriction'] ?? null;
    }
}
$orderAdminDate = $block->formatDate(
    $block->getOrderAdminDate($order->getCreatedAt()),
    \IntlDateFormatter::MEDIUM,
    true
);

$orderStoreDate = $block->formatDate(
    $order->getCreatedAt(),
    \IntlDateFormatter::MEDIUM,
    true,
    $block->getTimezoneForStore($order->getStore())
);

$dealerName  = $order->getFflDealer();
$dealerId    = $order->getSelectedFflDealerId();
$hasDealer   = $dealerId ? true : false;
$hasNormalProduct = false;
$hasFflProduct    = false;
$restrictedProducts = [];

foreach ($order->getAllVisibleItems() as $item) { // Use getAllVisibleItems to prevent duplicates
    
    // Skip free gifts
    $sku = (string)$item->getSku();
    $price = (float)$item->getPrice();
    $isFreeGift = ($price <= 0) || stripos($sku, 'FREE') !== false;
    if ($isFreeGift) {
        continue;
    }

    // Load product safely
    $product = null;
    try {
        $product = $this->productRepository->getById($item->getProductId());
    } catch (\Exception $e) {}

    // Determine FFL vs normal
    if ($product && $product->getData('ffl_selection_required')) {
        $hasFflProduct = true;
    } else {
        $hasNormalProduct = true;
    }

    // Restriction data
    $restrictionJson = $item->getData('orchid_restriction_level');

    if ($restrictionJson === null || $restrictionJson === '' || (string)$restrictionJson === '1') {
        continue;
    }

    $decoded = json_decode($restrictionJson, true);

    if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
        $restrictedProducts[] = [
            'name'     => $item->getName(),
            'level'    => isset($decoded['restriction']) ? (string)$decoded['restriction'] : (string)$restrictionJson,
            'shipping' => isset($decoded['shipping_restriction']) ? (string)$decoded['shipping_restriction'] : null,
            'age'      => isset($decoded['age_restriction']) ? (string)$decoded['age_restriction'] : null,
        ];
    } else {
        // Handle non-JSON values (like 3 or 5)
        $restrictedProducts[] = [
            'name'     => $item->getName(),
            'level'    => (string)$restrictionJson,
            'shipping' => null,
            'age'      => null,
        ];
    }
}


