<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="ahyUpdateVendorCommand" xsi:type="object">Ahy\FlxPoint\Console\UpdateVendor</item>
                <item name="ahyUpdateProductCommand" xsi:type="object">Ahy\FlxPoint\Console\UpdateProduct</item>
                <item name="ahyImportProductsCommand" xsi:type="object">Ahy\FlxPoint\Console\ImportProducts</item>
            </argument>
        </arguments>
    </type>

    <type name="Ahy\FlxPoint\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Ahy\FlxPoint\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">FlxPoint</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Ahy\FlxPoint\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
</config>