<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
	<type name="Magento\Framework\Console\CommandList">
		<arguments>
			<argument name="commands" xsi:type="array">
				<item name="ImportUpdateProducts" xsi:type="object">Ahy\BarcodeLookup\Console\Command\ImportUpdateProducts</item>
			</argument>
		</arguments>
	</type>
	<type name="Ahy\BarcodeLookup\Logger\Handler">
		<arguments>
			<argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
		</arguments>
	</type>
	<type name="Ahy\BarcodeLookup\Logger\Logger">
		<arguments>
			<argument name="name" xsi:type="string">BarcodeLookup</argument>
			<argument name="handlers" xsi:type="array">
				<item name="system" xsi:type="object">Ahy\BarcodeLookup\Logger\Handler</item>
			</argument>
		</arguments>
	</type>

	<type name="Ahy\BarcodeLookup\Logger\BarcodeUpdateHandler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Ahy\BarcodeLookup\Logger\BarcodeUpdateLogger">
        <arguments>
            <argument name="name" xsi:type="string">BarcodeUpdate</argument>
            <argument name="handlers" xsi:type="array">
                <item name="update" xsi:type="object">Ahy\BarcodeLookup\Logger\BarcodeUpdateHandler</item>
            </argument>
        </arguments>
    </type>
</config>
