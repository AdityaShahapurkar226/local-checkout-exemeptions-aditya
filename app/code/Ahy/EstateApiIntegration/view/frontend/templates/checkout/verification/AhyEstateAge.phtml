                    class="h-12 px-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ahy-blue focus:outline-none">

                    <option value="">Select Day</option>

                    <?php if ($magewire->getSelectedMonth() && $magewire->getSelectedYear()): ?>
                        <?php
                        $daysInMonth = cal_days_in_month(
                            CAL_GREGORIAN,
                            $magewire->getSelectedMonth(),
                            $magewire->getSelectedYear()
                        );
                        ?>
                        <?php for ($i = 1; $i <= $daysInMonth; $i++): ?>
                            <option value="<?= $i ?>"><?= $i ?></option>
                        <?php endfor; ?>
                    <?php endif; ?>
                </select>
