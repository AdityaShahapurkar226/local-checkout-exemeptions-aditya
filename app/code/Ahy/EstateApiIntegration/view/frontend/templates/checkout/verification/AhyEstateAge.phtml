                    wire:change="calculateAge"
                    class="h-12 px-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ahy-blue focus:outline-none">

                    <option value="">Select Month</option>

                    <?php for ($i = 1; $i <= 12; $i++): ?>
                        <option value="<?= $i ?>">
                            <?= date('F', mktime(0, 0, 0, $i, 1)) ?>
                        </option>
                    <?php endfor; ?>
                </select>
