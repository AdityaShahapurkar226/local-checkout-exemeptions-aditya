    <?php if ($magewire->getAge() == null || $magewire->getAge() < 18): ?>
        <div class="component-messenger message pl-6 mb-4 relative warning"
            x-data="{
                component: null,
                show: false,
                message: {
                    type: 'error',
                    text: 'Something\u0020went\u0020wrong.'
                },
                dispatched: 0
            }"
            @age:validation:error.window="
                component = null
                show = true
                message = Object.assign(message, $event.detail.message)
                if ($event.detail.component) {
                    component = $event.detail.component.id || null
                }
                dispatched++
                Magewire.hook('message.received', (message, component) => {
                    if (component.id === $event.detail.component.id) {
                        show = false
                        dispatched = 0
                    }
                })
            "
            x-on:age:validation:success.window="show = false"
            x-bind:class="message.type"
            x-bind:data-testid="component ? `${component}-message` : ''"
            x-show="show" x-transition:enter="transition ease-in duration-300"
            x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-out duration-300"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            data-testid="checkout.ffl.verification-message">
            <span x-text="message.text"></span>
            <div class="absolute -left-1.5 -top-1.5"
                x-show="dispatched >= 2 && message.type !== 'success'"
                x-transition.opacity>
                <span class="flex h-4 w-4">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 border-2 border-white shadow-xl"></span>
                </span>
            </div>
            <button class="close cursor-pointer" title="Close" x-on:click.prevent="show = false; dispatched = 0">
