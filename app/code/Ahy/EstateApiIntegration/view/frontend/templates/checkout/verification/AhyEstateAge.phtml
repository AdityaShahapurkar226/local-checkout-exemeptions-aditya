    <?php if ($magewire->getAge() !== null && $magewire->getAge() >= 18): ?>

        <div class="mt-4"
            x-data="{
                agreeComplianceValue: false,
                asPurchaserValue: false,
                fireArmsWarrantyValue: false,
                fireArmsReturnPolicyValue: false,

                notify() {
                    window.dispatchEvent(new CustomEvent('compliance-state-updated', {
                        detail: {
                            isVerified:
                                this.agreeComplianceValue
                                && this.asPurchaserValue
                                && this.fireArmsWarrantyValue
                                && this.fireArmsReturnPolicyValue
                        }
                    }));
                },

                syncMagewire() {
                    if (typeof Magewire === 'undefined') return;

                    Magewire.emit('updateAgreeCompliance', this.agreeComplianceValue);
                    Magewire.emit('updateAsPurchaser', this.asPurchaserValue);
                    Magewire.emit('updateFireArmsWarranty', this.fireArmsWarrantyValue);
                    Magewire.emit('updateFireArmsReturnPolicy', this.fireArmsReturnPolicyValue);
                },

                init() {
                    // keep Continue disabled initially
                    this.notify();
                }
            }">

