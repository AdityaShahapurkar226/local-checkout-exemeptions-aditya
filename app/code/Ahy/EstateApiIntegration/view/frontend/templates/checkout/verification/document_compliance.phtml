    <script>
        (function() {
            const initAlpineComponent = () => {
                if (typeof Alpine !== 'undefined' && !Alpine.data('estateComplianceUpload')) {
                    Alpine.data('estateComplianceUpload', (uploadUrl, formKey, initialUploadStatus = false) => ({
                        uploadUrl: uploadUrl,
                        formKey: formKey,
                        file: null,
                        uploading: false,
                        success: false,
                        error: null,
                        isUploaded: initialUploadStatus,

                        init() {
                            const fileInput = document.getElementById('document-file-input');
                            if (fileInput) {
                                fileInput.value = '';
                            }
                            this.file = null;
                            this.success = false;
                            this.error = null;

                            this.updateValidationInput(this.isUploaded);

                            console.log('Document upload component initialized', {
                                isUploaded: this.isUploaded,
                                file: this.file
                            });
                        },

                        handleFile(event) {
                            this.file = event.target.files[0];
                            this.success = false;
                            this.error = null;
                            console.log('File selected:', this.file?.name);
                        },

                        clearFile(buttonEl) {
                            this.file = null;
                            this.success = false;
                            this.error = null;
                            // Find the file input in the same container and reset its value
                            const input = buttonEl.closest('.relative').querySelector('input[type="file"]');
                            if (input) input.value = '';
                            console.log('File cleared');
                        },

                        updateValidationInput(isUploaded) {
                            const hiddenInput = document.getElementById('isDocumentUploaded');
                            if (hiddenInput) {
                                hiddenInput.value = isUploaded ? 'true' : 'false';
                                hiddenInput.setAttribute('aria-invalid', isUploaded ? 'false' : 'true');
                                console.log('Validation input updated:', {
                                    isUploaded
                                });
                            }
                            this.isUploaded = isUploaded;
                        },

                        async upload() {
                            if (!this.file) {
                                this.error = '✖ Please select a file to upload.';
                                return;
                            }

                            const maxSize = 5 * 1024 * 1024;
                            if (this.file.size > maxSize) {
                                this.error = '✖ File size must be less than 5MB.';
                                return;
                            }

                            const allowedTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
                            if (!allowedTypes.includes(this.file.type)) {
                                this.error = '✖ Invalid file type. Please upload PDF, JPG, PNG, or WebP files only.';
                                return;
                            }

                            this.uploading = true;
                            this.error = null;
                            this.success = false;

                            const formData = new FormData();
                            formData.append('document', this.file);
                            formData.append('form_key', this.formKey);

                            try {
                                console.log('Starting upload...', {
                                    fileName: this.file.name
                                });

                                const response = await fetch(this.uploadUrl, {
                                    method: 'POST',
                                    body: formData,
                                    credentials: 'same-origin',
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest'
                                    }
                                });

                                if (!response.ok) {
                                    throw new Error('Server returned ' + response.status);
                                }

                                const data = await response.json();
                                console.log('Upload response:', data);

                                if (data.success) {
                                    this.success = true;
                                    this.file = null;
                                    const form = document.getElementById('documentUploadForm');
                                    if (form) form.reset();
                                    this.updateValidationInput(true);
                                    if (typeof Magewire !== 'undefined') {
                                        console.log('Emitting documentUploaded event to Magewire');
                                        Magewire.emit('documentUploaded', true);
                                    }
                                    // document_compliance.phtml around line 326
                                    window.dispatchEvent(new CustomEvent('document-uploaded', {
                                        detail: {
                                            uploaded: true
                                        }
                                    }));
                                    console.log('Document upload completed successfully');
                                } else {
                                    this.error = '✖ ' + (data.message || 'Upload failed. Please try again.');
                                    console.error('Upload failed:', data.message);
                                }
                            } catch (err) {
                                console.error('Upload error:', err);
                                this.error = '✖ An error occurred during upload: ' + err.message;
                            } finally {
                                this.uploading = false;
                            }
                        }
                    }));
                }
            };

            document.addEventListener('alpine:init', initAlpineComponent);
            if (typeof Alpine !== 'undefined') initAlpineComponent();
            document.addEventListener('magewire:load', () => initAlpineComponent());

            if (typeof magewire !== 'undefined') {
                magewire.hook('message.processed', () => {
                    if (typeof Alpine !== 'undefined') {
                        const wrapper = document.getElementById('document-compliance-wrapper');
                        if (wrapper) {
                            Alpine.discoverUninitializedComponents((el) => {
                                if (wrapper.contains(el)) Alpine.initializeComponent(el);
                            });
                        }
                    }
                });
            }
        })();
    </script>

<?php
