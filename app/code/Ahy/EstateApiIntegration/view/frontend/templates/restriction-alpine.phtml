<script>
document.addEventListener('alpine:init', () => {
    Alpine.store('stateAgeApi', {

        /* ----------------------------------------------------------------
           STATE
        ---------------------------------------------------------------- */
        showModal:    false,
        modalMessage: '',
        age:          '',
        resolve:      null,

        // Server-rendered flags (PHP → JS)
        isLoggedIn:                    <?= $isLoggedIn            ? 'true' : 'false' ?>,
        customerState:                 <?= json_encode($customerState  ?: '') ?>,
        customerCity:                  <?= json_encode($customerCity   ?: '') ?>,
        shouldShowRegulatedProductModal: <?= $showRegulatedProductModal ? 'true' : 'false' ?>,
        isMagazineProduct:             <?= $isMagazineProduct     ? 'true' : 'false' ?>,

        // Guest modal
        showGuestModal:     false,
        guestModalTitle:    '',
        guestModalMessage:  '',
        guestResolve:       null,
        guestState:         '',
        guestCity:          '',
        guestAge:           '',
        showGuestCityField: false,
        showGuestAgeField:  false,
        citiesLoading:      false,
        availableCities:    [],

        // Toast
        toast: { show: false, message: '' },

        /* ----------------------------------------------------------------
           HELPERS — derive rule type from product flags
        ---------------------------------------------------------------- */
        _ruleType() {
            return this.shouldShowRegulatedProductModal ? 'regulated_weapon' : 'magazine';
        },

        /* ----------------------------------------------------------------
           TOAST
        ---------------------------------------------------------------- */
        showToast(message, duration = 3500) {
            console.log('[TOAST]', message);
            this.toast.message = message;
            this.toast.show    = true;
            setTimeout(() => { this.toast.show = false; }, duration);
        },

        /* ----------------------------------------------------------------
           AGE MODAL (logged-in users)
        ---------------------------------------------------------------- */
        openModal() {
            console.log('[MODAL] Opening age verification modal');
            return new Promise((resolve) => {
                this.age          = '';
                this.modalMessage = '';
                this.resolve      = resolve;
                this.showModal    = true;
            });
        },

        submit() {
            const parsed = parseInt(this.age);
            if (!this.age || isNaN(parsed) || parsed < 1 || parsed > 120) {
                this.showToast('Please enter a valid age (1–120).');
                return;
            }
            console.log('[MODAL] Age confirmed:', parsed);
            this.showModal = false;
            this.resolve?.(parsed);
            this.resolve = null;
        },

        cancel() {
            console.log('[MODAL] Age verification cancelled');
            this.showModal = false;
            this.resolve?.(null);
            this.resolve = null;
        },

        /* ----------------------------------------------------------------
           GUEST MODAL — state change: fetch cities from API
        ---------------------------------------------------------------- */
        async onGuestStateChange() {
            // Reset city state whenever the state selection changes
            this.availableCities    = [];
            this.guestCity          = '';
            this.showGuestCityField = false;

            if (!this.guestState) {
                console.log('[CITY API] No state selected — skipping fetch');
                return;
            }

            const ruleType = this._ruleType();
            const url      = `/rest/V1/get-available-cities?ruleType=${encodeURIComponent(ruleType)}&state=${encodeURIComponent(this.guestState)}`;

            console.log('[CITY API] Fetching cities →', url);
            this.citiesLoading      = true;

            try {
                const res = await fetch(url);

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }

                const raw = await res.json();
                console.log('[CITY API] Raw response:', raw);

                if (!Array.isArray(raw)) {
                    throw new Error('Expected an array of cities from API');
                }

                // Deduplicate, preserve order, keep lowercase for consistent comparison
                const seen   = new Set();
                const cities = [];
                for (const c of raw) {
                    const normalised = String(c).trim().toLowerCase();
                    if (normalised && !seen.has(normalised)) {
                        seen.add(normalised);
                        cities.push(normalised);
                    }
                }

                console.log('[CITY API] Deduplicated cities:', cities);

                // If the only entry is "other city" there is nothing meaningful to pick —
                // hide the dropdown and let city default to null on submit.
                const isOtherCityOnly =
                    cities.length === 1 && cities[0] === 'other city';

                if (cities.length === 0 || isOtherCityOnly) {
                    console.log('[CITY API] No selectable cities (empty or "other city" only) — hiding city field, city will be null');
                    this.availableCities    = [];
                    this.showGuestCityField = false;
                } else {
                    this.availableCities    = cities;
                    this.showGuestCityField = true;
                    console.log('[CITY API] Cities populated:', cities);
                }

            } catch (err) {
                console.error('[CITY API] Error fetching cities:', err);
                this.showToast('Failed to load cities. Please try again.');
                this.showGuestCityField = false;
            } finally {
                this.citiesLoading = false;
            }
        },

        /* ----------------------------------------------------------------
           GUEST MODAL — open / submit / cancel
        ---------------------------------------------------------------- */
        openGuestModal(showAge = false) {
            console.log('[GUEST MODAL] Opening — showAge:', showAge);
            return new Promise((resolve) => {
                this.guestState         = '';
                this.guestCity          = '';
                this.guestAge           = '';
                this.availableCities    = [];
                this.showGuestCityField = false;
                this.showGuestAgeField  = showAge;
                this.citiesLoading      = false;
                this.guestModalTitle    = showAge
                    ? 'Age & Location Verification'
                    : 'Location Verification';
                this.guestModalMessage  = showAge
                    ? 'Please select your state, city (if applicable), and confirm your age to continue.'
                    : 'Please select your state and city (if applicable) to continue.';
                this.guestResolve       = resolve;
                this.showGuestModal     = true;
            });
        },

        submitGuest() {
            // --- Validate state ---
            if (!this.guestState) {
                this.showToast('Please select your state.');
                return;
            }

            // --- Validate city when the dropdown is visible ---
            if (this.showGuestCityField && !this.citiesLoading && !this.guestCity) {
                this.showToast('Please select your city.');
                return;
            }

            // --- Validate age when required ---
            if (this.showGuestAgeField) {
                const parsedAge = parseInt(this.guestAge);
                if (!this.guestAge || isNaN(parsedAge) || parsedAge < 1 || parsedAge > 120) {
                    this.showToast('Please enter a valid age (1–120).');
                    return;
                }
            }

            // --- Resolve city value ---
            // "other city" from the API → send null to the backend
            let resolvedCity = null;
            if (this.showGuestCityField && this.guestCity) {
                resolvedCity = this.guestCity.toLowerCase() === 'other city'
                    ? null
                    : this.guestCity;
            }

            const payload = {
                state: this.guestState,
                city:  resolvedCity,
                age:   this.showGuestAgeField ? parseInt(this.guestAge) : 0,
            };
            console.log('[GUEST MODAL] Submitting payload:', payload);

            this.showGuestModal = false;
            this.guestResolve?.(payload);
            this.guestResolve = null;
        },

        cancelGuest() {
            console.log('[GUEST MODAL] Cancelled');
            this.showGuestModal = false;
            this.guestResolve?.(null);
            this.guestResolve = null;
        },

        /* ----------------------------------------------------------------
           VALIDATION API  →  POST /rest/V1/restriction/validate
        ---------------------------------------------------------------- */
        async callApi(productId, age = 0, state = null, city = null) {
            const useState = state || this.customerState;
            let   useCity  = city;

            // For logged-in users city may come from the customer profile
            if (useCity === undefined || useCity === null) {
                useCity = this.customerCity || null;
            }

            // Normalise city: lowercase + trim, keep null as null
            if (useCity && typeof useCity === 'string') {
                useCity = useCity.toLowerCase().trim() || null;
            }

            const requestBody = {
                productId: productId,
                state:     useState,
                city:      useCity,   // null when "other city" or no city required
                age:       age,
            };

            console.log('[VALIDATE API] POST /rest/V1/restriction/validate →', requestBody);

            if (!useState) {
                this.showToast('State is required for validation.');
                return 0;
            }

            try {
                const res = await fetch('/rest/V1/restriction/validate', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(requestBody),
                });

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }

                const data = await res.json();
                console.log('[VALIDATE API] Response:', data);

                if (data.restricted) {
                    if (data.reason && data.reason.startsWith('__AGE_REQUIRED__|')) {
                        const requiredAge = parseInt(data.reason.split('|')[1]);
                        console.warn('[VALIDATE API] Age restriction — minimum age:', requiredAge);
                        this.showToast(`You must be at least ${requiredAge} years old to purchase this product.`);
                    } else {
                        console.warn('[VALIDATE API] Restricted:', data.reason);
                        this.showToast(data.reason || 'This product cannot be shipped to your location.');
                    }
                    return 0;
                }

                console.log('[VALIDATE API] Product is allowed for this location/age.');
                return 1;

            } catch (err) {
                console.error('[VALIDATE API] Error:', err);
                this.showToast('Validation check failed. Please try again.');
                return 0;
            }
        },

        /* ----------------------------------------------------------------
           MAIN ENTRY POINT  —  called by add-to-cart / buy buttons
        ---------------------------------------------------------------- */
        async check(productId) {
            console.log('[CHECK] Starting restriction check', {
                productId,
                isLoggedIn:  this.isLoggedIn,
                isMagazine:  this.isMagazineProduct,
                isRegulated: this.shouldShowRegulatedProductModal,
            });

            // No restriction applies to this product — allow immediately
            if (!this.isMagazineProduct && !this.shouldShowRegulatedProductModal) {
                console.log('[CHECK] No restriction — allowed');
                return 1;
            }

            /* ---------- GUEST FLOW ---------- */
            if (!this.isLoggedIn) {

                if (this.shouldShowRegulatedProductModal) {
                    // Regulated weapon: collect state, city AND age; send all to API
                    console.log('[CHECK] Guest flow — regulated weapon (age required)');

                    const data = await this.openGuestModal(true);

                    if (!data) {
                        console.log('[CHECK] Guest modal cancelled');
                        return 0;
                    }

                    return await this.callApi(
                        productId,
                        data.age,
                        data.state,
                        data.city
                    );
                }

                if (this.isMagazineProduct) {
                    console.log('[CHECK] Guest flow — magazine (age required)');

                    const data = await this.openGuestModal(true);

                    if (!data) {
                        console.log('[CHECK] Guest modal cancelled');
                        return 0;
                    }

                    console.log('[CHECK] Guest magazine — age from modal:', data.age);

                    return await this.callApi(
                        productId,
                        data.age,   // ← use the age the user actually entered
                        data.state,
                        data.city
                    );
                }

                return 1;
            }

            /* ---------- LOGGED-IN FLOW ---------- */
            console.log('[CHECK] Logged-in flow — opening age modal');

            const age = await this.openModal();

            if (!age) {
                console.warn('[CHECK] Age verification cancelled or invalid');
                this.showToast('Age verification is required to continue.');
                return 0;
            }

            console.log('[CHECK] Logged-in — age from modal:', age, '| state:', this.customerState, '| city:', this.customerCity);

            return await this.callApi(
                productId,
                age,
                this.customerState,
                this.customerCity || null
            );
        },

    }); // end Alpine.store
}); // end alpine:init
</script>

<style>
    .toaster-margin-top {
        margin-top: 11rem !important;
    }
