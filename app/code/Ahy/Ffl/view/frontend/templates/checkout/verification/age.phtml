                fireArmsWarrantyValue: false, 
                fireArmsReturnPolicyValue: false,
                agreementCompliances: function (event) {
                    var inputId = (event.currentTarget.querySelector('input').id); // Output the ID of the input element that triggered the event
                    var inputEl = document.getElementById(inputId);
                    var inputName = inputEl.getAttribute('name'); // Get the name attribute of the input element
                    var inputXmodelName = inputEl.getAttribute('x-model'); // Get the x-model name attribute of the input element

                    // Update the corresponding data property based on the input name
                    this[inputXmodelName] = !inputEl.checked;

                    // Emit the corresponding event based on the input name
                    switch (inputName) {
                    case 'agree-compliance':
                        Magewire.emit('updateAgreeCompliance', this[inputXmodelName]);
                        break;
                    case 'as-purchaser':
                        Magewire.emit('updateAsPurchaser', this[inputXmodelName]);
                        break;
                    case 'fire-arms-warranty':
                        Magewire.emit('updateFireArmsWarranty', this[inputXmodelName]);
                        break;
                    case 'fire-arms-return-policy':
                        Magewire.emit('updateFireArmsReturnPolicy', this[inputXmodelName]);
                        break;
                    default:
                        break;
                    }
                }
            }"
