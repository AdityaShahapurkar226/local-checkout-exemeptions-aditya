<?xml version="1.0" ?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
		<item name="js_config" xsi:type="array">
			<item name="provider" xsi:type="string">ahy_ffl_fflcentres_form.fflcentres_form_data_source</item>
		</item>
		<item name="label" xsi:type="string" translate="true">General Information</item>
		<item name="template" xsi:type="string">templates/form/collapsible</item>
	</argument>
	<settings>
		<buttons>
			<button name="back" class="Ahy\Ffl\Block\Adminhtml\FflCentres\Edit\BackButton"/>
			<button name="delete" class="Ahy\Ffl\Block\Adminhtml\FflCentres\Edit\DeleteButton"/>
			<button name="save" class="Ahy\Ffl\Block\Adminhtml\FflCentres\Edit\SaveButton"/>
			<button name="save_and_continue" class="Ahy\Ffl\Block\Adminhtml\FflCentres\Edit\SaveAndContinueButton"/>
		</buttons>
		<namespace>ahy_ffl_fflcentres_form</namespace>
		<dataScope>data</dataScope>
		<deps>
			<dep>ahy_ffl_fflcentres_form.fflcentres_form_data_source</dep>
		</deps>
	</settings>
	<dataSource name="fflcentres_form_data_source">
		<argument name="data" xsi:type="array">
			<item name="js_config" xsi:type="array">
				<item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
			</item>
		</argument>
		<settings>
			<submitUrl path="*/*/save"/>
		</settings>
		<dataProvider name="fflcentres_form_data_source" class="Ahy\Ffl\Model\FflCentres\DataProvider">
			<settings>
				<requestFieldName>fflcentres_id</requestFieldName>
				<primaryFieldName>fflcentres_id</primaryFieldName>
			</settings>
		</dataProvider>
	</dataSource>
	<fieldset name="general">
		<settings>
			<label>General</label>
		</settings>
		<field name="CentreName" formElement="input" sortOrder="10">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Centre Name</label>
				<dataScope>CentreName</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>
		<field name="zipcode" formElement="input" sortOrder="20">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">zipcode</label>
				<dataScope>zipcode</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>
		<field name="AddressLine1" formElement="input" sortOrder="30">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Address Line 1</label>
				<dataScope>AddressLine1</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>
		<field name="AddressLine2" formElement="input" sortOrder="40">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Address Line 2</label>
				<dataScope>AddressLine2</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="City" formElement="input" sortOrder="50">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">City</label>
				<dataScope>City</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>
		<field name="region_id" formElement="input" sortOrder="60">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Region Code</label>
				<dataScope>region_id</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">true</rule>
				</validation>
			</settings>
		</field>
		<field name="email" formElement="input" sortOrder="70">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Email</label>
				<dataScope>email</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="phone_no" formElement="input" sortOrder="80">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Phone no</label>
				<dataScope>phone_no</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="fax" formElement="input" sortOrder="90">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Fax</label>
				<dataScope>fax</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="working_time" formElement="input" sortOrder="100">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Working time</label>
				<dataScope>working_time</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="transfer_fee" formElement="input" sortOrder="110">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Tranfser fee</label>
				<dataScope>transfer_fee</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="lat" formElement="input" sortOrder="120">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">lat</label>
				<dataScope>lat</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="long" formElement="input" sortOrder="130">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">FflCentres</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">long</label>
				<dataScope>long</dataScope>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
	</fieldset>
</form>
