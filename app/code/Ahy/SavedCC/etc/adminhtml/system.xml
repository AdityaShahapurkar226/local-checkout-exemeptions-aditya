<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment" translate="label">
            <group id="ahy_savedcc" translate="label" sortOrder="905" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Saved Credit Cards (Authorize.Net by Ahy Consulting)</label>

                <field id="active" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Saved Credit Cards</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="validation_mode" translate="label" type="select" sortOrder="20"
                    showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Validation Mode</label>
                    <source_model>Ahy\SavedCC\Model\Config\Source\ValidationMode</source_model>
                    <comment>Select whether to validate cards in Test Mode, Live Mode, or disable validation</comment>
                </field>
            </group>
        </section>
    </system>
</config>
