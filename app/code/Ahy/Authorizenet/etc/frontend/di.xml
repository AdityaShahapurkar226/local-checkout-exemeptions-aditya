<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Hyva\Checkout\Model\Magewire\Payment\PlaceOrderServiceProvider">
        <arguments>
            <argument name="placeOrderServiceList" xsi:type="array">
                <item name="authnetahypayment" xsi:type="object">Ahy\Authorizenet\Model\Magewire\Payment\PlaceOrderService</item>
            </argument>
        </arguments>
    </type>
    <!-- Disable Venmo Buttom -->
    <type name="Magento\Paypal\Model\SdkUrl">
        <arguments>
            <argument name="unsupportedPaymentMethods" xsi:type="array">
                <item name="venmo" xsi:type="string">venmo</item>
            </argument>
        </arguments>
    </type>
    <!-- Saved CC User Dashboard viewmodel -->
    <type name="Hyva\Theme\Model\ViewModelRegistry">
        <arguments>
            <argument name="viewModels" xsi:type="array">
                <item name="customerVaultCards" xsi:type="object">Ahy\Authorizenet\ViewModel\CustomerVaultCards</item>
            </argument>
        </arguments>
    </type>
    <!-- Edit card viewmodel -->
    <type name="Magento\Framework\View\Element\Block\ArgumentInterface">
        <arguments>
            <argument name="EditVaultCard" xsi:type="object">Ahy\Authorizenet\ViewModel\Customer\EditVaultCard</argument>
        </arguments>
    </type>
    
    <!-- This has been addded to manage the sequence of payment methods at Checkout -->
    <preference for="Hyva\Checkout\ViewModel\Checkout\Payment\MethodList"
                type="Ahy\Authorizenet\ViewModel\Checkout\Payment\MethodList"/>

    <!-- Saved cards -->
    <type name="Hyva\Checkout\Model\Magewire\Payment\PlaceOrderServiceProvider">
        <arguments>
            <argument name="placeOrderServiceList" xsi:type="array">
                <item name="customervaultcards" xsi:type="object">Ahy\Authorizenet\Model\Magewire\Payment\PlaceOrderService\CustomerVaultCards</item>
            </argument>
        </arguments>
    </type>

</config>