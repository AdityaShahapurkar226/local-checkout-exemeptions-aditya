<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
<script>
    function initCustomerAddressEdit(hasAddress = false) {
        return {
            // UI state
            showAddressModal: !hasAddress,
            showCardModal: hasAddress,
            toastMessage: '',
            showToastMessage: false,
            directoryData: {},
            availableRegions: {},
            selectedRegion: '',
            isZipRequired: true,
            isRegionRequired: true,

            // Lifecycle
            init() {
                this.observeAddCardButton();
                this.loadUSRegions();

                // If card modal is shown on init, load billing addresses
                if (this.showCardModal) {
                    setTimeout(() => this.loadBillingAddresses(), 300);
                }
            },

            // Attach click behavior to the Add Card button
            observeAddCardButton() {
                const attachListener = () => {
                    const addCardBtn = document.querySelector('#add-new-card-btn');
                    if (!addCardBtn) return;

                    if (addCardBtn.dataset.addrListenerAttached === '1') return;

                    addCardBtn.addEventListener('click', () => {
                        const billingSelect = document.querySelector('#billing-address-select');
                        const hasAddresses = !!(billingSelect && billingSelect.querySelectorAll('option').length > 1);

                        if (hasAddresses) {
                            this.showAddressModal = false;
                            this.showCardModal = true;
                            setTimeout(() => this.loadBillingAddresses(), 300);
                        } else {
                            this.showCardModal = false;
                            this.showAddressModal = true;
                        }
                    }, {
                        passive: true
                    });

                    addCardBtn.dataset.addrListenerAttached = '1';
                };

                attachListener();

                const observer = new MutationObserver(() => attachListener());
                observer.observe(document.body, {
                    childList: true,
                    subtree: true
                });
            },

            // Load US regions without country select
            loadUSRegions() {
                fetch('/rest/V1/directory/countries/US')
                    .then(res => res.json())
                    .then(data => {
                        this.availableRegions = data.available_regions || [];
                        const regionSelect = this.$refs.region_id;
                        if (regionSelect) {
                            regionSelect.innerHTML = '';
                            const placeholder = document.createElement('option');
                            placeholder.value = '';
                            placeholder.textContent = '<?= $escaper->escapeJs(__('Please select a state.')) ?>';
                            regionSelect.appendChild(placeholder);

                            this.availableRegions.forEach((r) => {
                                const opt = document.createElement('option');
                                opt.value = String(r.id ?? r.code ?? r.name ?? '');
                                opt.textContent = String(r.name ?? '');
                                regionSelect.appendChild(opt);
                            });
                        }
                    })
                    .catch(err => console.error('Error loading US regions', err));
            },

            // Populate billing addresses in the card modal
            loadBillingAddresses() {
                const waitForBillingSelect = (cb) => {
                    const maxWaitMs = 4000;
                    const start = Date.now();
                    const tick = () => {
                        const sel = document.querySelector('#billing-address-select');
                        if (sel) return cb(sel);
                        if (Date.now() - start > maxWaitMs) return;
                        setTimeout(tick, 150);
                    };
                    tick();
                };

                fetch('/rest/V1/customers/me', {
                        method: 'GET',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then((res) => {
                        if (!res.ok) throw new Error('Failed to load customer data');
                        return res.json();
                    })
                    .then((data) => {
                        waitForBillingSelect((billingSelect) => {
                            const addrs = Array.isArray(data?.addresses) ? data.addresses : [];
                            const defaultOption = document.createElement('option');
                            defaultOption.value = '';
                            defaultOption.disabled = true;
                            defaultOption.selected = true;
                            defaultOption.textContent = '<?= $escaper->escapeJs(__('-- Select an address --')) ?>';

                            const frag = document.createDocumentFragment();
                            frag.appendChild(defaultOption);

                            addrs.forEach((addr) => {
                                const opt = document.createElement('option');
                                opt.value = String(addr.id ?? '');
                                const line = [
                                    addr.firstname,
                                    addr.lastname,
                                    Array.isArray(addr.street) ? addr.street.join(', ') : addr.street,
                                    addr.city,
                                    addr?.region?.region,
                                    addr.postcode,
                                    addr.country_id
                                ].filter(Boolean).join(', ');
                                opt.textContent = line;
                                frag.appendChild(opt);
                            });

                            billingSelect.innerHTML = '';
                            billingSelect.appendChild(frag);
                            const addNewOpt = document.createElement('option');
                            addNewOpt.value = '__add__';
                            addNewOpt.textContent = '<?= $escaper->escapeJs(__('Add New Address')) ?>';
                            billingSelect.appendChild(addNewOpt);
                            // const defaultBilling = addrs.find((a) => a.default_billing || a.defaultBilling);
                            // if (defaultBilling) billingSelect.value = String(defaultBilling.id);
                        });
                    })
                    .catch((err) => {
                        console.error('Error fetching customer data:', err);
                    });
            },

            submitAddressForm() {
                const form = document.getElementById('form-validate');
                if (!form) return;

                const formData = new FormData(form);

                fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then((res) => res.text())
                    .then((html) => {
                        const isSuccess =
                            html.includes('message-success') ||
                            (!html.includes('form-address-edit') && !html.includes('validation-failed'));

                        if (isSuccess) {
                            this.showToast('Address saved successfully');
                            this.showAddressModal = false;
                            this.showCardModal = true;
                            setTimeout(() => this.loadBillingAddresses(), 300);
                            return;
                        }

                        // If not successful, try to extract validation errors from the returned HTML
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const errors = doc.querySelectorAll('.mage-error');

                        // Clear old errors
                        form.querySelectorAll('.mage-error').forEach(e => e.remove());

                        // Append new errors to matching fields
                        errors.forEach(err => {
                            const fieldId = err.getAttribute('for');
                            if (fieldId) {
                                const field = form.querySelector(`#${fieldId}`);
                                if (field && field.parentNode) {
                                    field.parentNode.appendChild(err);
                                }
                            }
                        });
                    })
                    .catch((err) => {
                        console.error(err);
                        alert('Something went wrong');
                    });
            },
            showToast(message) {
                this.toastMessage = message;
                this.showToastMessage = true;
                setTimeout(() => this.showToastMessage = false, 3000); // hide after 3s
            }

        };
    }

    function encryptPanWithPhpCompatibleAes(pan, secretKeyString) {
        const shaHex = CryptoJS.SHA256(secretKeyString).toString(CryptoJS.enc.Hex);
        const phpStyleKeyAscii = shaHex.substring(0, 32);
        const keyWA = CryptoJS.enc.Utf8.parse(phpStyleKeyAscii);
        const iv = CryptoJS.lib.WordArray.random(16);
        const encrypted = CryptoJS.AES.encrypt(
            CryptoJS.enc.Utf8.parse(pan),
            keyWA, {
                iv: iv,
                mode: CryptoJS.mode.CBC,
                padding: CryptoJS.pad.Pkcs7
            }
        );

        const combined = iv.clone().concat(encrypted.ciphertext);
        return CryptoJS.enc.Base64.stringify(combined);
    }

    function onSubmitForm(event) {
        event.preventDefault();

        const form = event.target;
        if (!form) return;
        // Get Alpine scope from the nearest x-data wrapper
        const alpine = Alpine.$data(form.closest('[x-data]'));
        alpine.isSubmitting = true; // show blur + loader
        const cardInput = form.querySelector('[name="card_number"]');
        const cvvInput = form.querySelector('[name="cvv"]');
        const cardExpirationMonthInput = form.querySelector('[name="expiration_month"]');
        const cardExpirationYearInput = form.querySelector('[name="expiration_year"]');

        if (!cardInput || !cvvInput) {
            alert('Card number or CVV input not found');
            return;
        }

        const panRaw = (cardInput.value || '').replace(/\s+/g, '');
        const cvvRaw = (cvvInput.value || '').trim();

        if (!panRaw || !cvvRaw) {
            alert('Please fill all required credit card fields.');
            alpine.isSubmitting = false;
            return;
        }

        try {
            const SECRET_KEY = 'my_static_secret_key';
            const encCard = encryptPanWithPhpCompatibleAes(panRaw, SECRET_KEY);
            cardInput.value = encCard;

            const encCvv = encryptPanWithPhpCompatibleAes(cvvRaw, SECRET_KEY);
            cvvInput.value = encCvv;
            const encExpirationMonth = encryptPanWithPhpCompatibleAes(cardExpirationMonthInput.value, SECRET_KEY);
            const option = document.createElement("option");
            option.text = encExpirationMonth;
            option.value = encExpirationMonth;
            cardExpirationMonthInput.appendChild(option);
            cardExpirationMonthInput.value = encExpirationMonth;

            const encExpirationYear = encryptPanWithPhpCompatibleAes(cardExpirationYearInput.value, SECRET_KEY);
            const optionYear = document.createElement("option");
            optionYear.text = encExpirationYear;
            optionYear.value = encExpirationYear;
            cardExpirationYearInput.appendChild(optionYear);
            cardExpirationYearInput.value = encExpirationYear;


            console.log('Encrypted Expiration Month:', encExpirationMonth);
            console.log('Encrypted Expiration Year:', encExpirationYear);

            // Submit form
            form.submit();
        } catch (err) {
            console.error('Encryption failed', err);
            alert('Something went wrong while encrypting your card details. Please try again.');
            alpine.isSubmitting = false;
        }
    }
