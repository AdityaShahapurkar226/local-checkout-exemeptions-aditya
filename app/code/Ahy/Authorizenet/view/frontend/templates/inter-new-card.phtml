                    'JCB': '/media/icons/jcb.svg',
                    'Diners Club/ Carte Blanche': '/media/icons/diners.svg',
                    'Unknown': '/media/icons/unknown-code.svg',
                };
                return map[this.cardType] || map['Unknown'];
            },
            checkCardType() {
                this.cardType = this.detectCardType(this.cardNumber);
