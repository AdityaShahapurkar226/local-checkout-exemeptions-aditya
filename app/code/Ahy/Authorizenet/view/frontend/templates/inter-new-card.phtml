/**
 * Formats an address into a single line.
 *
 * @param \Magento\Customer\Api\Data\AddressInterface $address
 * @return string
 */
function formatAddressLine(\Magento\Customer\Api\Data\AddressInterface $address): string
{
    $regionName = $address->getRegion() ? (string) $address->getRegion()->getRegion() : '';
    $parts = [
        (string) $address->getFirstname(),
        (string) $address->getLastname(),
        implode(', ', array_filter((array) $address->getStreet())),
        (string) $address->getCity(),
        $regionName,
        (string) $address->getPostcode(),
        (string) $address->getCountryId(),
    ];
    return implode(', ', array_values(array_filter($parts, static fn($p) => $p !== '')));
}

