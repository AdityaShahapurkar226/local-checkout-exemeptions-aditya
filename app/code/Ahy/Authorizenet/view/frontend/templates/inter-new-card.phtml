            detectCardType(cardNumber) {
                const patterns = {
                        Visa: /^4/,
                        Mastercard: /^5[1-5]/,
                        'American Express': /^3[47]/,
                        Discover: /^6(?:011|5[0-9]{2})/,
                        JCB: /^(?:2131|1800|35\\d{3})/,
                        'Diners Club/ Carte Blanche': /^3(?:0[0-5]|[68])/,
                    };
                for (const [type, regex] of Object.entries(patterns)) {
                        if (regex.test(cardNumber)) return type;
                }
                return 'Unknown';
            },
            getCardImage() {
                const map = {
                    'Visa': '/media/icons/visa.svg',
                    'Mastercard': '/media/icons/mastercard.svg',
