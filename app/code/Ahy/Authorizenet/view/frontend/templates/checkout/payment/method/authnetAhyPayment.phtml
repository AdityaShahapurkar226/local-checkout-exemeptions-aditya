    <div class=""
        x-data="{
            cardNumber: '',
            cardType: 'Unknown',
            detectCardType: function(cardNumber) {
                const visaPattern = /^4/;
                const mastercardPattern = /^5[1-5]/;
                const amexPattern = /^3[47]/;
                const discoverPattern = /^6(?:011|5[0-9]{2})/;
                const jcbPattern = /^(?:2131|1800|35\d{3})/;
                const dinersClubPattern = /^3(?:0[0-5]|[68])/;

                switch (true) {
                    case visaPattern.test(cardNumber):
                        return 'Visa';
                    case mastercardPattern.test(cardNumber):
                        return 'Mastercard';
                    case amexPattern.test(cardNumber):
                        return 'American Express';
                    case discoverPattern.test(cardNumber):
                        return 'Discover';
                    case jcbPattern.test(cardNumber):
                        return 'JCB';
                    case dinersClubPattern.test(cardNumber):
                        return 'Diners Club/ Carte Blanche';
                    default:
                        return 'Unknown';
                }
            },
            isValidCardNumber: function(cardNumber) {
                // Perform additional validation if needed
                // (e.g., check length, Luhn algorithm, etc.)
                return cardNumber.length >= 1;
            },
            checkCardType: function() {
                if (this.isValidCardNumber(this.cardNumber)) {
                    this.cardType = this.detectCardType(this.cardNumber);
                } else {
                    this.cardType = 'Unknown';
                }
            },
            getCardImage: function() {
                const imageMap = {
                    'Visa': '/media/icons/visa.svg',
                    'Mastercard': '/media/icons/mastercard.svg',
                    'American Express': '/media/icons/amex.svg',
                    'Discover': '/media/icons/discover.svg',
                    'JCB': '/media/icons/jcb.svg',
                    'Diners Club/ Carte Blanche': '/media/icons/diners.svg',
                    'Unknown': '/media/icons/unknown-code.svg'
                };

                return imageMap[this.cardType] || imageMap['Unknown'];
            }
        }">
