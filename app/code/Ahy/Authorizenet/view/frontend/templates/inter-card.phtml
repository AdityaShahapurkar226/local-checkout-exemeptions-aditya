                <path class="opacity-75" fill="currentColor"
                    d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
            </svg>
        </div>
        <form method="POST"
            @submit.prevent="isSubmitting = true; submitForm($event)"
            action="<?= $escaper->escapeUrl($block->getUrl('customer/account/updateSavedCard')) ?>"
            class="space-y-6">
            <input type="hidden" name="form_key" value="<?= $escaper->escapeHtml($block->getFormKey()) ?>" />
            <input type="hidden" name="vault_token_id" value="<?= $tokenId ?>" />
            <input type="hidden" name="payment_profile_id" value="<?= $escaper->escapeHtmlAttr($token->getGatewayToken()) ?>" />

            <!-- Address dropdown -->
