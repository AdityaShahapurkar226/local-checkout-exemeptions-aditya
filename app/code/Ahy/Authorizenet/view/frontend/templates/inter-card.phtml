use Magento\Framework\Escaper;

$escaper = $escaper ?? new Escaper();
$token = $block->getData('token');
$details = $block->getData('details') ?? [];
$addressHelper = $block->getData('address_helper');

$tokenId = (int)$token->getEntityId();
$expiration = explode('/', $details['expirationDate'] ?? '00/0000');
$expMonth = $expiration[0] ?? '';
$expYear = $expiration[1] ?? '';
$addresses = $addressHelper->getCustomerAddresses();
$hasAddress = !empty($addresses);
?>

<div x-data="{
    expireMonth: '<?= $escaper->escapeJs($expMonth) ?>',
    expireYear: '<?= $escaper->escapeJs($expYear) ?>',
    expiryError: '',
    today: new Date(),

    cardNumber: '',
    cardType: '<?= $escaper->escapeJs($details['type'] ?? 'UNKNOWN') ?>',

    detectCardType(cardNumber) {
        const patterns = {
            Visa: /^4/,
            Mastercard: /^5[1-5]/,
            'American Express': /^3[47]/,
            Discover: /^6(?:011|5[0-9]{2})/,
            JCB: /^(?:2131|1800|35\\d{3})/,
            'Diners Club/ Carte Blanche': /^3(?:0[0-5]|[68])/,
        };
        for (const [type, regex] of Object.entries(patterns)) {
            if (regex.test(cardNumber)) return type;
        }
        return 'Unknown';
    },

    getCardImage() {
        const imageMap = {
            'Visa': '/media/icons/visa.svg',
            'Mastercard': '/media/icons/mastercard.svg',
            'American Express': '/media/icons/amex.svg',
            'Discover': '/media/icons/discover.svg',
            'JCB': '/media/icons/jcb.svg',
            'Diners Club/ Carte Blanche': '/media/icons/diners.svg',
            'Unknown': '/media/icons/unknown-code.svg',
        };
        return imageMap[this.cardType] || imageMap['Unknown'];
    },

    checkCardType() {
        this.cardType = this.detectCardType(this.cardNumber.replace(/\\D/g, ''));
    },

    validateExpiry() {
        if (!this.expireMonth || !this.expireYear) {
            this.expiryError = '';
            return;
        }
        const exp = new Date(`${this.expireYear}-${this.expireMonth}-01`);
        exp.setMonth(exp.getMonth() + 1); // include full expiry month
        this.expiryError = exp <= this.today ? 'Card expiry date must be in the future.' : '';
    },

    onSubmitForm(e) {
        this.validateExpiry();
        if (this.expiryError) {
            e.preventDefault();
        }
    },

    handleAddressChange() {
        if (this.$refs.billingSelect.value === '__add__') {
            window.location.href = '<?= $block->getUrl("customer/address/new") ?>';
        }
    }
}">
    <div x-data="cardForm()">
        <div
            x-show="isSubmitting"
            class="absolute inset-0 flex items-center justify-center bg-white/70 backdrop-blur-sm z-20">
            <svg class="animate-spin h-10 w-10 text-ahy-blue" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
