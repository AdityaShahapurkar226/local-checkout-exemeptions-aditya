declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Framework\Escaper;
use PayPal\Braintree\Block\GooglePay\Shortcut\Button;
use Ahy\GooglePay\ViewModel\GooglePay\RestrictVisibility;

/** @var Escaper $escaper */
/** @var Button $block */
/** @var RestrictVisibility $viewModel */

/** @var ViewModelRegistry $viewModels */

try {
    $id = sprintf('%s%s', $block->getContainerId(), random_int(PHP_INT_MIN, PHP_INT_MAX));
} catch (Exception $e) {
    /**
     * Exception only thrown if an appropriate source of randomness cannot be found.
     *
     * @link https://www.php.net/manual/en/function.random-int.php
     */
    $id = 0;
}


$viewModel = $block->getData('viewModel');
$shouldShowGooglePayButton = $viewModel->shouldShowButton();

?>
<?php if ($shouldShowGooglePayButton): ?>
    <div id="<?= $escaper->escapeHtmlAttr($id); ?>"
        x-data="initBraintreeGooglePayExpress(
            '<?= $escaper->escapeHtmlAttr($block->getMerchantId()); ?>',
            '<?= $escaper->escapeHtmlAttr($block->getClientToken()); ?>'
        )"
        @private-content-loaded.window="receiveCustomerData($event.detail.data)"
        x-init="$nextTick(() => { init() })"
        data-environment="<?= $escaper->escapeHtmlAttr($block->getEnvironment()); ?>"
        data-success="<?= $escaper->escapeUrl($block->getActionSuccess()); ?>"
        data-currency="<?= $escaper->escapeHtmlAttr($block->getCurrencyCode()); ?>"
        data-amount="<?= $escaper->escapeHtmlAttr($block->getAmount()); ?>"
        data-card-types="<?= $escaper->escapeHtmlAttr(implode(',', $block->getAvailableCardTypes())); ?>"
        data-color="<?= $escaper->escapeHtmlAttr($block->getBtnColor()); ?>"
        class="!w-full googlepay-minicart-logo <?= $escaper->escapeHtmlAttr($block->getExtraClassname()); ?>"></div>
<?php endif; ?>

