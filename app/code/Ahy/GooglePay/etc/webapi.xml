<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/googlepay/clear-nonce" method="POST">
        <service class="Ahy\GooglePay\Api\ClearNonceInterface" method="clearNonce"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/googlepay/frontend/log" method="POST">
        <service class="Ahy\GooglePay\Api\FrontendLoggerInterface" method="log"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
