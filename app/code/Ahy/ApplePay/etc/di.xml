<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Hyva\CompatModuleFallback\Model\CompatModuleRegistry">
        <arguments>
            <argument name="compatModules" xsi:type="array">
                <item name="hyva-magento2-paypal-braintree" xsi:type="array">
                    <item name="original_module" xsi:type="string">PayPal_Braintree</item>
                    <item name="compat_module" xsi:type="string">Ahy_ApplePay</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="PayPal\Braintree\Block\ApplePay\Shortcut\Button">
        <arguments>
            <argument name="data" xsi:type="array">
                <item name="template" xsi:type="string">Ahy_ApplePay::applepay/button.phtml</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Checkout\Model\PaymentInformationManagement">
        <plugin name="ahy_applepay_paymentinformation_plugin"
                type="Ahy\ApplePay\Plugin\Checkout\Model\PaymentInformationManagementPlugin"
                sortOrder="10"/>
    </type>
    <type name="Magento\Checkout\Model\GuestPaymentInformationManagement">
        <plugin name="ahy_applepay_guestpaymentinformation_before"
                type="Ahy\ApplePay\Plugin\Checkout\Model\GuestPaymentInformationManagementPlugin"
                sortOrder="10"/>
    </type>
    <type name="Magento\Checkout\Model\ShippingInformationManagement">
        <plugin name="ahy_applepay_shippinginformation_before"
                type="Ahy\ApplePay\Plugin\Checkout\Model\ShippingInformationManagementPlugin"
                sortOrder="10"
                disabled="false"/>
    </type>

   <preference for="Ahy\ApplePay\Api\FrontendLoggerInterface"
                type="Ahy\ApplePay\Model\FrontendLogger" />

    <!-- Logger config -->
    <type name="Ahy\ApplePay\Logger\ApplePayLogger">
        <arguments>
            <argument name="name" xsi:type="string">apple_pay</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Ahy\ApplePay\Logger\Handler\ApplePay</item>
            </argument>
        </arguments>
    </type>
</config>
