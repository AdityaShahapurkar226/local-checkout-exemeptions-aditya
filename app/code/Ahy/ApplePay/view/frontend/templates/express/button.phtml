declare(strict_types=1);

use PayPal\Braintree\Block\ApplePay\Shortcut\Button;
use Magento\Framework\Escaper;
use Ahy\GooglePay\ViewModel\ApplePay\RestrictVisibility;

/** @var Escaper $escaper */
/** @var Button $block */
/** @var RestrictVisibility $viewModel */

try {
    $id = sprintf('%s%s', $block->getContainerId(), random_int(PHP_INT_MIN, PHP_INT_MAX));
} catch (Exception $e) {
    /**
     * Exception only thrown if an appropriate source of randomness cannot be found.
     *
     * @link https://www.php.net/manual/en/function.random-int.php
     */
    $id = 0;
}

$viewModel = $block->getData('viewModel');
$shouldShowApplePayButton = $viewModel->shouldShowButton();

?>
<?php if ($shouldShowApplePayButton && $block->getAmount() > 0): ?>
    <div id="<?= $escaper->escapeHtmlAttr($id); ?>"
        x-data="initBraintreeApplePayExpress()"
        x-init="$nextTick(() => { init() })"
        data-success="<?= $escaper->escapeUrl($block->getActionSuccess()); ?>"
        data-client-token="<?= $escaper->escapeHtmlAttr($block->getClientToken()); ?>"
        data-display-name="<?= $escaper->escapeHtmlAttr($block->getMerchantName()); ?>"
        data-amount="<?= $escaper->escapeHtmlAttr(number_format((float)$block->getAmount(), 2, '.', '')); ?>"
        data-is-logged-in="<?= $escaper->escapeHtmlAttr($block->isCustomerLoggedIn() ? 'true' : 'false'); ?>"
        data-store-code="<?= $escaper->escapeHtmlAttr($block->getStorecode()); ?>"
        data-quote-id="<?= $escaper->escapeHtmlAttr($block->getQuoteId()); ?>"
        class="braintree-applepay-minicart <?= $escaper->escapeHtmlAttr($block->getExtraClassname()); ?>"></div>
<?php endif; ?>

