<?php

declare(strict_types=1);

use Ahy\ApplePay\ViewModel\Payment\Method\ApplePay as ApplePayViewModel;
use Ahy\ApplePay\ViewModel\Braintree as BraintreeViewModel;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;

/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */
/** @var Escaper $escaper */

/** @var BraintreeViewModel $braintreeViewModel */
$braintreeViewModel = $viewModels->require(BraintreeViewModel::class);
/** @var ApplePayViewModel $applePayViewModel */
$applePayViewModel = $viewModels->require(ApplePayViewModel::class);
?>

<div>
    <script>
        const braintreeApplePay = () => {
            return {
                applePayToken: false,
                braintreeApplePayMethod: "applepay",
                braintreeApplePayId: "braintreeApplePay",
                showApplePayButtonOnCheckout: window.ApplePaySession,

                hasApplePayToken() {
                    return this.applePayToken;
                },

                hasNoApplePayToken() {
                    return !this.applePayToken;
                },

                initialise() {
                    if (!window.ApplePaySession) {
                        return;
                    }

                    const applePayContainer = document.getElementById('payment-method-option-braintree_applepay');
                    applePayContainer.classList.add('braintree-applepay-visible');

                    const requiredJsFiles = [];

                    if (!window.braintree?.client) {
                        requiredJsFiles.push(this.createScriptLoadPromise('https://js.braintreegateway.com/web/3.111.0/js/client.min.js'));
                    }

                    if (!window.braintree?.applePay) {
                        requiredJsFiles.push(this.createScriptLoadPromise('https://js.braintreegateway.com/web/3.111.0/js/apple-pay.min.js'));
                    }

                    if (!window.applePayScript) {
                        requiredJsFiles.push(this.createScriptLoadPromise('https://applepay.cdn-apple.com/jsapi/v1/apple-pay-sdk.js'));
                        window.applePayScript = true;
                    }

                    Promise.all(requiredJsFiles)
                        .then(this.initialiseApplePay.bind(this))
                        .then(this.addEvents.bind(this));
                },

                async initialiseApplePay() {
                    if (this.applePayToken) {
                        return;
                    }

                    if (!window.braintree.client || !window.ApplePaySession.canMakePayments()) {
                        return;
                    }

                    const clientInstance = await window.braintree.client.create({
                        authorization: "<?= $escaper->escapeJs($braintreeViewModel->getClientToken()) ?>",
                    });

                    const applePayInstance = await window.braintree.applePay.create({
                        client: clientInstance,
                    });

                    const applePayButton = document.createElement('apple-pay-button');
                    applePayButton.buttonstyle = "black";
                    applePayButton.addEventListener('click', async (e) => {
                        this.showLoader();

                        const totalElement = document.querySelector('[data-grand-total]');
                        const grandTotal = totalElement?.dataset?.grandTotal;

                        var paymentRequest = applePayInstance.createPaymentRequest({
                            total: {
                                label: '<?= $escaper->escapeJs($applePayViewModel->getMerchantName()) ?>',
                                amount: Number(grandTotal).toFixed(2),
                            },
                            currencyCode: '<?= $escaper->escapeJs($braintreeViewModel->getCurrency()) ?>',
                        });

                        if (!paymentRequest) {
                            // TODO: Test this:
                            fetch('/rest/V1/applepay/frontend/log', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    message: 'Failed to create Apple Pay paymentRequest',
                                    level: 'error'
                                })
                            });

                            this.showError('<?= $escaper->escapeJs(
                                __('Braintree ApplePay unable to create paymentRequest.')
                            ) ?>');
                        }

                        try {
                            var session = new ApplePaySession(1, paymentRequest);
                            session.onvalidatemerchant = function(event) {
                                applePayInstance.performValidation({
                                    validationURL: event.validationURL,
                                    displayName: '<?= $escaper->escapeJs($applePayViewModel->getMerchantName()) ?>',
                                }, function(validationErr, merchantSession) {
                                    if (validationErr) {
                                        session.abort();
                                        console.error('Braintree ApplePay Error validating merchant: ', validationErr);
                                        this.showError('<?= $escaper->escapeJs(__('Error validating merchant.')) ?>');

                                        // TODO: Test this:
                                        fetch('/rest/V1/applepay/frontend/log', {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({
                                                message: {
                                                    event: 'merchant_validation_failed',
                                                    error: validationErr
                                                },
                                                level: 'error'
                                            })
                                        });

                                        return;
                                    }

                                    session.completeMerchantValidation(merchantSession);
                                });
                            };

                            session.oncancel = () => {
                                this.showError('<?= $escaper->escapeJs(__('Payment cancelled.')) ?>');

                                // TODO: Test this:
                                fetch('/rest/V1/applepay/frontend/log', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({
                                        message: 'Apple Pay session cancelled by user',
                                        level: 'warning'
                                    })
                                });
                            }

                            session.onpaymentauthorized = (event) => {
                                applePayInstance.tokenize({
                                    token: event.payment.token
                                }, async (tokenizeErr, payload) => {
                                    if (tokenizeErr) {
                                        console.error('Error tokenizing Apple Pay:', tokenizeErr);
                                        this.showError('<?= $escaper->escapeJs(__('Error authorizing payment.')) ?>');
                                        session.completePayment(ApplePaySession.STATUS_FAILURE);

                                        // TODO: Test this:
                                        fetch('/rest/V1/applepay/frontend/log', {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({
                                                message: {
                                                    event: 'applepay_tokenization_failed',
                                                    error: tokenizeErr
                                                },
                                                level: 'error'
                                            })
                                        });

                                        return;
                                    }

                                    await Magewire.find('checkout.payment.method.' + this.braintreeApplePayMethod).setToken(payload.nonce);
                                    this.applePayToken = true;
                                    this.clearError();
                                    session.completePayment(ApplePaySession.STATUS_SUCCESS);
                                });
                            };

                            session.begin();
                        } catch (err) {
                            console.error('Braintree ApplePay Unable to create ApplePaySession', err);
                            this.showError('<?= $escaper->escapeJs(__('Unable to create Apple Pay session.')) ?>');
                            return;
                        }
                    });

                    const applePayElement = document.getElementById('braintreeApplePayButton');

                    if (applePayElement && !applePayElement.childElementCount) {
                        applePayElement.append(applePayButton);
                    }
                },

                addEvents() {
                    window.addEventListener('checkout:init:after', event => {
                        hyvaCheckout.validation.register(this.braintreeApplePayId, async function () {
                        if (!this.applePayToken) {
                            this.showError('<?= $escaper->escapeJs(
                                __('Please complete payment validation with Apple Pay first.')
                            ) ?>');
                        }

                        return this.applePayToken || false;
                        }.bind(this), document.getElementById(this.braintreeApplePayId));
                    }, {
                        once: true
                    });

                    hyvaCheckout.validation.register(this.braintreeApplePayId, async function () {
                        if (!this.applePayToken) {
                            this.showError('<?= $escaper->escapeJs(
                                __('Please complete payment validation with Apple Pay first.')
                            ) ?>');
                        }

                        return this.applePayToken || false;
                    }.bind(this), document.getElementById(this.braintreeApplePayId));

                    window.Magewire.hook('message.processed', (message, component) => {
                        if (component.id === 'checkout.billing-details.address-list') {
                            this.applePayToken = false;

                            // TODO: Test this:
                            fetch('/rest/V1/applepay/frontend/log', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    message: 'Apple Pay token cleared due to address change',
                                    level: 'info'
                                })
                            });
                        }

                        const method = message.updateQueue[0].method;

                        if (method !== 'setToken'
                            && component.id === 'checkout.payment.method.applepay'
                            && !this.applePayToken) {
                            this.initialiseApplePay();
                        }
                    }, { once: true });

                    Magewire.on('payment_method_selected', (obj) => {
                        if (!obj) return;

                        const method = obj.method;
                        if (method !== this.braintreeApplePayMethod.replace('-', '_')) {
                            hyvaCheckout.validation.remove(this.braintreeApplePayId);
                        }
                    });
                },

                createScriptLoadPromise(url) {
                    return new Promise((resolve, reject) => {
                        const script = document.createElement('script');
                        script.src = url;

                        script.addEventListener('load', function() {
                            resolve();
                        }, false);

                        script.addEventListener('error', function(event) {

                            // TODO: Test this:
                            fetch('/rest/V1/applepay/frontend/log', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    message: {
                                        event: 'script_load_failed',
                                        src: url
                                    },
                                    level: 'error'
                                })
                            });

                            reject();
                        }, false);

                        document.body.appendChild(script);
                    })
                },

                showLoader() {
                    window.dispatchEvent(new Event('magewire:loader:start'));
                },

                hideLoader() {
                    window.dispatchEvent(new Event('magewire:loader:done'));
                },

                showError(message) {
                    this.hideLoader();
                    hyvaCheckout.payment.dispatchExceptionMessage(
                        message,
                        'error'
                    );
                },

                clearError() {
                    hyvaCheckout.payment.dispatchSuccessMessage('');
                }
            }
        };

        window.addEventListener('alpine:init', () => Alpine.data('braintreeApplePay', braintreeApplePay), { once: true })
    </script>
    <!-- <?//php $hyvaCsp->registerInlineScript(); ?> -->
</div>
<style>
    apple-pay-button {
        display: inline-block;
        width: 100%;
    }

    apple-pay-button .apple-pay-btn {
        padding: 0.4rem;
        border-radius: 100vh;
    }
</style>
