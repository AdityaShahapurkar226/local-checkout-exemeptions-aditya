<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <!-- <head>
        <css src="Ahy_ApplePay::css/apple-pay.css" defer="defer"/>
    </head> -->

    <body>
        <referenceContainer name="checkout.cart.methods">
            <block 
                class="PayPal\Braintree\Block\ApplePay\Shortcut\Button"
                name="apple.cart.button"
                template="Ahy_ApplePay::express/button.phtml"
                after="checkout.cart.shortcut.buttons"
            >
                <arguments>
                    <argument name="button_id" xsi:type="string">apple-cart</argument>
                    <argument name="alias" xsi:type="string">cart</argument>
                    <argument name="viewModel" xsi:type="object">Ahy\ApplePay\ViewModel\RestrictVisibility</argument>
                </arguments>
            </block>
        </referenceContainer>

        <!-- <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                name="apple.cart.express.js"
                template="Ahy_ApplePay::express/express-js.phtml"/>
        </referenceContainer> -->
    </body>
</page>
