<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="payment_method_assign_data">
        <observer name="bitrail_gateway_data_assign" instance="BitRail\PaymentGateway\Observer\DataAssignObserver" />
    </event>
    <event name="payment_method_is_active">
        <observer name="disable_payment" instance="BitRail\PaymentGateway\Observer\PaymentMethodAvailableObserver" />
    </event>
</config>
