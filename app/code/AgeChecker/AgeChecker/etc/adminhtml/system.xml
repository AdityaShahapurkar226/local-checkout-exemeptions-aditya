<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../Magento/Config/etc/system_file.xsd">
    <system>
        <tab id="agechecker" translate="label" sortOrder="400">
            <label>Age Verification</label>
        </tab>

        <section id="agechecker" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>AgeChecker.Net</label>
            <tab>agechecker</tab>
            <resource>AgeChecker_AgeChecker::agechecker_agechecker</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Settings</label>
                <field id="enabled" type="select" translate="label comment" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="enable_on_all_pages" type="select" translate="label comment" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable On All Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>
                        This should only be enabled if AgeChecker needs to bind to elements that are not on checkout pages.
                    </comment>
                </field>
                <field id="api_key" type="text" translate="label comment" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Key</label>
                    <comment>
                        The API key for this domain. Find it in the websites tab of your AgeChecker.Net account.
                    </comment>
                </field>
                <field id="name" type="text" translate="label comment" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Store Name</label>
                    <comment>
                        Display name of your store in the popup.
                    </comment>
                </field>
                <field id="element" type="text" translate="label comment" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Element Selector</label>
                    <comment>
                        Element selector to attach the popup event to. (You may need to change this if you use a custom theme or checkout extension)
                    </comment>
                </field>
                <field id="categories" type="text" translate="label comment" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exclusion Categories</label>
                    <comment>
                        Age verification will not be required if all of the cart products are in these category IDs. (Comma separated i.e. "1, 2, 3")
                    </comment>
                </field>
                <field id="category_specific_api_keys" type="text" translate="label comment" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Category Specific API Keys</label>
                    <comment>
                        This value should be key value pairs where the category ID is the key and the API key is the value. Prioritized from first to last. (i.e. {"1": "api_key_one", "2": "api_key_two"})
                    </comment>
                </field>
                <field id="before_load_script" type="textarea" translate="label comment" sortOrder="7" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Before Load Script</label>
                    <comment>
                        Custom code to run before the script is loaded. Use "return;" to prevent loading.
                    </comment>
                </field>
                <field id="client_config" type="textarea" translate="label comment" sortOrder="8" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Advanced Config</label>
                    <comment>
                        Other additional configuration options from our client API.
                    </comment>
                </field>
            </group>
        </section>

    </system>
</config>