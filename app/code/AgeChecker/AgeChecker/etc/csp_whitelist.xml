<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>   
                <value id="cdnjs-agechecker" type="host">*.agechecker.net</value>
                <value id="cdnjs-userway" type="host">cdn.userway.org</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>   
                <value id="cdncss-agechecker" type="host">*.agechecker.net</value>
                <value id="cdncss-userway" type="host">cdn.userway.org</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>   
                <value id="connect-agechecker" type="host">*.agechecker.net</value>
                <value id="connect-userway" type="host">*.userway.org</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>   
                <value id="img-agechecker" type="host">*.agechecker.net</value>
                <value id="img-userway" type="host">*.userway.org</value>
                <value id="blob" type="host">blob:</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>   
                <value id="img-agechecker" type="host">*.agechecker.net</value>
                <value id="font-userway" type="host">*.userway.org</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>