<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="Webkul\Marketplace\Block\Order\Items"  name="label_generator" template="Webkul_MpMultiShipping::order/labels.phtml" cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Webkul\MpMultiShipping\ViewModel\Shipping</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceContainer name="label_generator">
            <block class="Magento\Framework\View\Element\Template" name="packages_generation_form" template="Webkul_MpMultiShipping::order/packages.phtml" cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Webkul\MpMultiShipping\ViewModel\Shipping</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
