<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
     <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor" title="Admin Login As Vendor" sortOrder="10" >
                    <resource id="Webkul_AdminLoginAsVendor::menu" title="Menu" sortOrder="10">
                        <resource id="Webkul_AdminLoginAsVendor::index" title="Manage Login Attempts" sortOrder="20" />
                    </resource>
                    <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_support" title="Support" sortOrder="20">
                        <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_userguide" title="User Guide" sortOrder="10" />
                        <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_extension" title="Store Extension" sortOrder="20" />
                        <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_uvdesk" title="Ticket/Customisations" sortOrder="30" />
                        <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_services" title="Services" sortOrder="40" />
                        <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_reviews" title="Reviews" sortOrder="50" />
                    </resource>     
                </resource>   
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Webkul_AdminLoginAsVendor::adminloginasvendor_config" title="Admin LoginAsVendor Config" sortOrder="50" />
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>