<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
	<acl>
		<resources>
			<resource id="Magento_Backend::admin">
				<resource id="Webkul_Marketplace::marketplace" title="Marketplace Management" sortOrder="10" >
					
					<resource id="Webkul_MpAssignProduct::manager" title="Manage Assign Products" sortOrder="20" >
						<resource id="Webkul_MpAssignProduct::product" title="Assign Products List" sortOrder="10" />
						<resource id="Webkul_MpAssignProduct::addproduct" title="Add Assign Product" sortOrder="20" />
						<resource id="Webkul_MpAssignProduct::massupload" title="Mass Assign Product Upload" sortOrder="30" />
					</resource>
				</resource>
				<resource id="Magento_Backend::stores">
					<resource id="Magento_Backend::stores_settings">
						<resource id="Magento_Config::config">
							<resource id="Webkul_MpAssignProduct::config_mpassignproduct" title="Assign Product Settings" sortOrder="10" />
						</resource>
					</resource>
				</resource>
			</resource>
		</resources>
	</acl>
</config>