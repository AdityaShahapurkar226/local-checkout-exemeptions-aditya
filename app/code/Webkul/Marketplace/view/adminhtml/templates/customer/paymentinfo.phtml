<script>
    const regionsByCountry = <?= json_encode($regionsByCountry) ?>;

    function updateRegions(countryId, formType) {
        const regionSelect = document.getElementById(`billing_state_${formType}`);
        const regionInput = document.getElementById(`billing_state_text_${formType}`);

        regionSelect.innerHTML = '<option value=""><?= __('-- Select Region --') ?></option>';

        if (regionsByCountry[countryId] && regionsByCountry[countryId].length > 0) {
            regionSelect.style.display = 'inline-block';
            regionInput.style.display = 'none';
            regionInput.value = '';

            regionsByCountry[countryId].forEach(region => {
                const option = document.createElement('option');
                option.value = region.region_id;
                option.textContent = region.default_name;
                regionSelect.appendChild(option);
            });
        } else {
            regionSelect.style.display = 'none';
            regionInput.style.display = 'inline-block';
            regionInput.value = '';
        }
    }

    function validateFields(form) {
        let isValid = true;
        form.querySelectorAll('.admin__field-control').forEach(control => {
            const input = control.querySelector('input[required], select[required], textarea[required]');
            const errorLabel = control.querySelector('.admin__field-error');
            if (input) {
                if (!input.value.trim()) {
                    if (errorLabel) errorLabel.style.display = 'block';
                    isValid = false;
                } else {
                    if (errorLabel) errorLabel.style.display = 'none';
                }
            }
        });
        return isValid;
    }
</script>
