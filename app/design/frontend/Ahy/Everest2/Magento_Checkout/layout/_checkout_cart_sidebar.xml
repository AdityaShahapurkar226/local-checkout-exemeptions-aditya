<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Make PayPal render first -->
        <referenceBlock name="extra_actions">
            <!-- Move Google Pay and Apple Pay below PayPal -->
            <move element="googlepay.minicart.button" destination="extra_actions" after="paypal.minicart.button"/>
            <move element="applepay.minicart.button" destination="extra_actions" after="googlepay.minicart.button"/>
        </referenceBlock>
    </body>
</page>
