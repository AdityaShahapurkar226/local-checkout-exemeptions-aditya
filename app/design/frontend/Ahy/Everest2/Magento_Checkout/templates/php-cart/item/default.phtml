                                        title="<?= $escaper->escapeHtmlAttr(__('Qty')) ?>"
                                        class="qty form-input px-2 py-2 w-20 text-center form-input shadow-none px-2 py-2 w-20 text-center focus:ring-transparent bg-transparent border-none font-bold text-lg invalid:ring-2 invalid:ring-red-500"
                                        required="required"
                                        min="0"
                                        @change="$event.target.form && $event.target.form.dispatchEvent(new Event('submit', { cancelable: true }));"
                                        data-role="cart-item-qty" />
                                    <button class="increment-qty plus font-black text-2xl text-ahy-blue hover:text-white duration-300 ease-out hover:ease-in group w-11 h-11 md:w-13 md:h-13 lg:w-15 lg:h-15 flex items-center justify-center transition hover:bg-ahy-blue rounded-full" onclick="handleQty(event)">＋</button>
                                </div>
                                <script>
                                    function handleQty(event) {
                                        event.preventDefault();
                                        event.stopPropagation();
                                        const inputElement = event.target.parentNode.querySelector('.qty');
                                        if (inputElement) {
                                            const currentValue = parseInt(inputElement.value);
                                            if (!isNaN(currentValue)) {

                                                if (event.target.classList.contains('plus')) {
                                                    inputElement.value = currentValue + 1;
                                                } else if (event.target.classList.contains('minus')) {
                                                    inputElement.value = Math.max(currentValue - 1, 0);
                                                }
                                                clearTimeout(inputElement.timeout);
                                                inputElement.timeout = setTimeout(() => {
                                                    inputElement.dispatchEvent(new Event('change'));
                                                }, 200);
                                            }
                                        }
                                    }
                                </script>
