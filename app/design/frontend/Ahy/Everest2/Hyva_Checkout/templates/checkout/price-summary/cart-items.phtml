declare(strict_types=1);

/** @var Escaper $escaper */
/** @var Template $block */
/** @var FormatterViewModel $formatterViewModel */
/** @var ViewModelRegistry $viewModels */
/** @var HeroiconsOutline $icons */
/** @var CartItems $magewire */
/** @var CartItemsViewModel $cartItemsViewModel */

use Hyva\Checkout\Magewire\Checkout\PriceSummary\CartItems;
use Hyva\Checkout\ViewModel\Checkout\PriceSummary\CartItems as CartItemsViewModel;
use Hyva\Checkout\ViewModel\Checkout\Formatter as FormatterViewModel;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

$icons = $viewModels->require(HeroiconsOutline::class);
$formatterViewModel = $viewModels->require(FormatterViewModel::class);
$cartItemsViewModel = $viewModels->require(CartItemsViewModel::class);

$quoteItems = $magewire->getQuoteItemData();
?>
<div x-data="{ expand: $wire.expand }">
    <?php if ($quoteItems): ?>
        <header class="hidden">
            <button type="button"
                    class="flex items-center justify-between w-full
                           font-bold
                           focus:outline-none"
                    x-on:click="expand = ! expand"
                    x-bind:title="expand ? '<?= $escaper->escapeHtml(__('Hide items')) ?>' : '<?= $escaper->escapeHtml(__('Show items')) ?>'"
            >
                <div class="flex relative">
                    <?= $icons->shoppingCartHtml('w-7 h-7', 26, 26) ?>

                    <span class="absolute
                                 top-0 right-0 h-5 w-5
                                 py-1 -mt-3 -mr-3
                                 text-xs text-center text-white
                                 leading-none
                                 rounded-full
                                 bg-primary block
                                 transform -translate-x-1 translate-y-1
                                 bg-opacity-90"
                    >
                        <?= /* @noEscape */ count($quoteItems) ?>
                    </span>
                </div>

                <span :class="{ 'transform rotate-180': expand }">
                    <?= $icons->chevronDownHtml('w-4 h-4', 16, 16) ?>
                </span>
            </button>
        </header>

        <div class="cart-items mt-4"
             x-show="expand"
             x-cloak
        >
        <h2 class="text-lg font-bold text-ahy-red mb-4"
            x-show="$store.estateApi.hasRestricted"
            x-transition.opacity
        >
            Some cart items are restricted at your location. Please edit cart to continue.
        </h2>
            <div class="flex flex-col h-full space-y-6 mt-4">
                <div class="relative grid gap-6 sm:gap-8">
                    <?php foreach ($quoteItems as $item): ?>
                        <div class="flex gap-4 mt-4">
                            <div class="flex-none relative">
                                <img src="<?= $escaper->escapeUrl($item['thumbnail']) ?>"
                                     width="75"
                                     height="75"
                                     alt="<?= $escaper->escapeHtmlAttr($item['name']) ?>"
                                     loading="lazy"
                                     class="rounded-md"
                                />

                                <span class="h-5 w-5 py-1
                                            text-xs text-center text-white
                                            leading-none font-bold 
                                            rounded-full
                                            bg-primary
                                            block absolute
                                            left-1/2 transform -translate-x-1/2 -translate-y-1/2
                                            shadow-md
                                            ring-4 ring-white"
                                >
                                    <?= /* @noEscape */ $item['qty'] ?>
                                </span>
                            </div>

                            <div class="flex-grow space-y-2">
                                <div class="flex gap-4 md:gap-0 justify-between">
                                    <div class="product-title">
                                        <p class="font-bold text-ahy-blue">
                                            <?= $escaper->escapeHtml($item['name']) ?>
                                        </p>

                                        <p class="text-sm">
                                            <?= $escaper->escapeHtml($item['sku']) ?>
                                        </p>
                                        <p class="text-sm">
                                            Qty: <?= /* @noEscape */ $item['qty'] ?>
                                        </p>
                                        
                                    </div>

                                    <div class="product-price">
                                        <span>
                                            <?= /* @noEscape */ $formatterViewModel->currency($item['price']) ?>
                                        </span>
                                    </div>
                                </div>

                                <?php $optionsRenderer = $cartItemsViewModel->getProductOptionsRenderer($block, $item['product_type']) ?>
                                <?php if ($optionsRenderer): ?>
                                    <?= /* @noEscape */ $optionsRenderer->setData('quote_item', $item)->toHtml() ?>
                                <?php endif ?>
                            </div>
                        </div>
                    <?php endforeach ?>
                </div>
            </div>
        </div>
    <?php endif ?>
</div>
