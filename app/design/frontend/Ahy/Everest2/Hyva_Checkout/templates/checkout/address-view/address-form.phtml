                    validateFirstName(value) {
                        const regex = /^[a-zA-Z ]*$/;
                        if (value.length > 0) {
                            if (value.length > 25) {
                                this.firstnameError = 'First name should be a maximum of 25 characters';
                                console.log('firstname Error:', this.firstnameError);
                            } else if (!regex.test(value)) {
                                this.firstnameError = 'First name should only contain alphabets and spaces';
                                console.log('firstname Error:', this.firstnameError);
                            } else {
                                this.firstnameError = '';
                            }
                        } else {
                            this.clearValidationError('firstname');
                        }
                    },
                    validateLastName(value) {
                        const regex = /^[a-zA-Z ]*$/;
                        if (value.length > 0) {
                            if (value.length > 25) {
                                this.lastnameError = 'Last name should be a maximum of 25 characters';
                                console.log('lastname Error:', this.lastnameError);
                            } else if (!regex.test(value)) {
                                this.lastnameError = 'Last name should only contain alphabets and spaces';
                                console.log('lastname Error:', this.lastnameError);
                            } else {
                                this.lastnameError = '';
                            }
                        } else {
                            this.clearValidationError('lastname');
                        }
                    },
                    validatePostcode(value) {
                        const regex = /^\d{5}(?:[-\s]\d{4})?$/;
                        if (value.length > 0) {
                            if (value.length > 10) {
                                this.postcodeError = 'Postal code should be a maximum of 10 characters';
                                console.log('Postal code Error:', this.postcodeError);
                            } else if (!regex.test(value)) {
                                this.postcodeError = 'Invalid Postal code';
                                console.log('Postal code Error:', this.postcodeError);
                            } else {
                                this.postcodeError = '';
                            }
                        } else {
                            this.clearValidationError('postcode');
                        }
                    },
                    validateTelephone(value) {
                        const regex = /^\+?1?[-.\s]?\(?(\d{3})\)?[-.\s]?(\d{3})[-.\s]?(\d{4})$/;

                        if (value.length < 9) {
                            this.telephoneError = 'Telephone number should be a minimum of 10 digits';
                            console.log('telephone Error:', this.telephoneError);
                        } else if (!regex.test(value) && value.length > 9) {
                            this.telephoneError = 'Invalid telephone number';
                            console.log('telephone Error:', this.telephoneError);
                        } else {
                            this.clearValidationError('telephone');
                        }
                    },
                    validateEmail(value) {
                        const regex = /^[\w-.]+@([\w-]+\.)+[\w-]{2,4}$/;
                        if (value.length > 0) {
                            if (!regex.test(value)) {
                                this.emailError = 'Invalid email address';
                            } else {
                                this.emailError = '';
                            }
                        } else {
                            this.clearValidationError('email');
                        }
                    },
