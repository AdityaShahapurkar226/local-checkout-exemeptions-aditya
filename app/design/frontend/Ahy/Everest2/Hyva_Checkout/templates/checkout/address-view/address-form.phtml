      <?php if ($magewire->canAutoSave()): ?>
          x-init="(() => {
            let timeout = null,
                dirty = false

            const doSave = async (isWithValidation = true) => {
                clearTimeout(timeout)

                if (isWithValidation) {
                    await validate()
                }

                try {
                    if (! dirty) {
                        return
                    }


                    dirty = false
                    await $wire.save(true)
                } catch (exception) {
                    // ignore
                }
            }

            const interactionCallback = () => {
                dirty = true

                clearTimeout(timeout)
                timeout = setTimeout(() => doSave(false), <?= $escaper->escapeJs($magewire->getAutoSaveTimeout()) ?>)
            }

            hyvaCheckout.navigation.addTask(doSave)

            Array.from($el.querySelectorAll('[data-autosave]')).forEach(field => {
                field.addEventListener('input', interactionCallback)
                field.addEventListener('change', interactionCallback)
            })
          })()"
          x-on:validate-address-form.window="if ($event.detail && $event.detail.form && $event.detail.form === '<?= $escaper->escapeJs($namespace) ?>') {
              return validate().catch(() => {})
          }

          if ($event.detail && $event.detail.event) {
              window.dispatchEvent(new CustomEvent($event.detail.event, { detail: $event.detail }))
          }
          "
          wire:loading.class="loading"
          wire:target="save"
