            <?= /* @noEscape */ $child->render($form, $child) ?>
        <?php endforeach ?>
    <?php endif ?>

    <?php if ($field->hasRelatives()): ?>
        <button id="second-street-toggle-button" x-show="isSecondStreetVisible" @click.prevent="toggleSecondStreetField()" class="w-full flex justify-end capitalize underline underline-offset-4">+ add line 2</button>
    </div>
    <?php endif ?>
    <?= /* @noEscape */ $field->getRenderer()->renderAfter($field, $form) ?>
