        </div>
         <?php switch ($fieldName):
            case 'firstname':
            case 'lastname':
            case 'postcode':
            case 'telephone':
            case 'email':
            case 'street':
            case 'city':
        ?>
            <div
                class="text-ahy-error"
                x-text="<?= $field->getName().'Error'?>"
                x-bind:class="<?= $field->getName().'Error'?> ? 'my-2 block' : 'hidden'"
            >
            </div>
        <?php
            break;
        default:
            break;
        endswitch; ?>
        <?php if($namespace == 'email'):?>
