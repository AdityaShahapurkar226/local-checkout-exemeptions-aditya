<?php

use Magento\Framework\Escaper;
use Magento\Wishlist\Block\Customer\Wishlist\Button;

/** @var Escaper $escaper */
/** @var Button $block */
$wishlist = $block->getWishlist();
?>
<?php if ($wishlist && $wishlist->getItemCollection()): ?>
    <?php foreach ($wishlist->getItemCollection() as $item): ?>
        <?php
        $productId = (int) $item->getProductId();
        $itemId = (int) $item->getId();
        ?>
    <?php endforeach; ?>
<?php endif; ?>

<?php if ($block->getWishlist()->getItemsCount() && $block->getWishlist()->isSalable()): ?>
    <button type="button"
        @click.prevent="addAllItemsToCart()"
        data-role="all-tocart"
        title="<?= $escaper->escapeHtmlAttr(__('Add All to Cart')) ?>"
        class="action tocart btn bg-ahy-red hover:bg-ahy-red-light rounded-full px-4 py-2 rounded bg-blue-600 text-white transition">
        <span><?= $escaper->escapeHtml(__('Add All to Cart')) ?></span>
    </button>
<?php endif; ?>

<script>
    document.addEventListener('alpine:init', () => {
        const store = Alpine.store('estateApi');

        const allToCartBtn = document.querySelector('[data-role="all-tocart"]');
        if (allToCartBtn) {
            allToCartBtn.addEventListener('click', async (event) => {
                event.preventDefault();
                event.stopImmediatePropagation();

                const buttons = document.querySelectorAll('[data-role="tocart"]');

                for (const button of buttons) {
                    const productId = parseInt(button.dataset.productId);
                    const itemId = button.dataset.itemId;

                    const restrictionResult = await store.checkProductRestriction(productId, null);
                    console.log(`Restriction result for product ${productId}:`, restrictionResult);

                    const container = document.querySelector(`[data-item-id-wrapper="${itemId}"]`);
                    if (restrictionResult !== 1) {
                        highlightRestricted(container, '[data-role="price-column"]');

                        continue;
                    }

                    try {
                        if (typeof store.addToCartByWishlistItem === 'function') {
                            await store.addToCartByWishlistItem({
                                product_id: productId
                            });

                            if (typeof hyva !== "undefined" && typeof hyva.postForm === "function") {
                                hyva.postForm({
                                    action: '/wishlist/index/remove',
                                    data: {
                                        item: itemId,
                                        uenc: window.btoa(window.location.href)
                                    }
                                });
                            }
                        }
                    } catch (err) {
                        console.error(`Error adding product ${productId}:`, err);
                        store.showNotification?.(`Failed to add product ${productId}`, 'error');
                    }
                }
            });
        }

        function highlightRestricted(container) {
            if (!container) return;

            const itemId = container.dataset.itemIdWrapper;
            const card = document.querySelector(`.product-item-info[data-item-id-wrapper="${itemId}"]`);

            if (card) {
                card.classList.add('border', 'border-red-500', 'rounded-md', 'p-2');
            }   
            

            // Optional: show message below the product card
            if (!container.querySelector('.restriction-message')) {
                const message = document.createElement('div');
                message.className = 'restriction-message text-red-700 font-semibold mt-2';
                message.textContent = 'This product is restricted and cannot be added to cart.';
                container.appendChild(message);
            }
        }


    });
</script>