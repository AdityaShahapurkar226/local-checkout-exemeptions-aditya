                updateTotalPrice(itemConfig = this.itemConfig){
                    const itemData = JSON.parse(itemConfig);
                    this.basePrice = itemData.parent_info.price;
                    this.totalPrice = this.basePrice;
                    this.oldTotalPrice = this.basePrice;
                    this.configurableProductCount = 0;

                    const packList = document.querySelector('.amrelated-pack-list-ahy');
                    if(packList){
                        const checkedInputs = packList.querySelectorAll('input[type="checkbox"]:checked');

                        if(checkedInputs){
                            checkedInputs.forEach((input) => {
                                const productId = input.getAttribute('data-product-id');
                                const productPrice = itemData.products[productId].price;
                                const productOldPrice = itemData.products[productId].old_price;
                                const productType = input.getAttribute('data-product-type');
                                this.totalPrice += productPrice;
                                this.oldTotalPrice += productOldPrice;
                                if(productType === 'configurable'){
                                    this.configurableProductCount++;
                                } else if(productType === 'simple') {
                                    //
                                }
                            });
                        }
                    }
                },
                setSimpleProductPackFormData(){
                    const packList = document.querySelector('.amrelated-pack-list-ahy');
                    if(packList){
                        const checkedInputs = packList.querySelectorAll('input[type="checkbox"]:checked');

                        const simpleProductPackEl = document.getElementById('simple-product-pack-data');
                        if(simpleProductPackEl){
                            simpleProductPackEl.innerHTML = '';
                        }
                        if(checkedInputs){
                            checkedInputs.forEach((input) => {
                                const productId = input.getAttribute('data-product-id');
                                const productType = input.getAttribute('data-product-type');
                                if(productType === 'simple') {
                                    // loop through the array of selected simple options
                                    if(simpleProductPackEl){

                                        const simpleProductPackOptionInput = document.createElement('input');
                                        simpleProductPackOptionInput.name = `amrelated_products[${productId}]`;
                                        simpleProductPackOptionInput.type = 'hidden';
                                        simpleProductPackOptionInput.value = 1;

                                        const simpleProductPackInputs = simpleProductPackEl.querySelectorAll('input');
                                        // Create a Set to keep track of unique input names
                                        const uniqueSimpleInputNames = new Set();
                                        // Loop through the inputs and remove any duplicates
                                        simpleProductPackInputs.forEach(input => {
                                            // Get the input name attribute
                                            const inputName = input.getAttribute('name');
                                            // If the input name is already in the set, remove the input element
                                            if (uniqueSimpleInputNames.has(inputName)) {
                                                input.remove();
                                            }
                                            // Add the input name to the set
                                            uniqueSimpleInputNames.add(inputName);
                                        });

                                        // Check if the input name is already in the set before adding the new input element
                                        if (!uniqueSimpleInputNames.has(simpleProductPackOptionInput.name)) {
                                            simpleProductPackEl.appendChild(simpleProductPackOptionInput);
                                        }
                                    }
                                }
                            });
                        }
                    }
                },
                setConfigurableProductPackFormData(){
                    this.unsetConfigurableProductPackFormData();
                    const configurableProductPackEl = document.getElementById('configurable-product-pack-data');
                    if(configurableProductPackEl){
                        this.swatchItemData.forEach((option) => {
                            // loop through the array of selected configurable options
                            const configurableProductPackOptionInput = document.createElement('input');
                            configurableProductPackOptionInput.name = 'amrelated_products_popup[]';
                            configurableProductPackOptionInput.type = 'hidden';
                            configurableProductPackOptionInput.id = `product-${option.configurableProductId}`;
                            configurableProductPackOptionInput.value = `product=${option.configurableProductId}&selected_configurable_option=&related_product=&item=0&form_key=${hyva.getFormKey()}&super_attribute[144]=${option.attributes.sizeAttrId}&super_attribute[93]=${option.attributes.colorAttrId}&qty=1`;

                            const configurableProductPackInputs = configurableProductPackEl.querySelectorAll('input');
                            // Create a Set to keep track of unique input names
                            const uniqueConfigurableInputNames = new Set();
                            // Loop through the inputs and remove any duplicates
                            configurableProductPackInputs.forEach(input => {
                                // Get the input name attribute
                                const inputName = input.getAttribute('id');
                                // If the input name is already in the set, remove the input element
                                if (uniqueConfigurableInputNames.has(inputName)) {
                                    input.remove();
                                }
                                // Add the input name to the set
                                uniqueConfigurableInputNames.add(inputName);
                            });

                            // Check if the input name is already in the set before adding the new input element
                            if (!uniqueConfigurableInputNames.has(configurableProductPackOptionInput.name)) {
                                configurableProductPackEl.appendChild(configurableProductPackOptionInput);
                            }
                        });
                    }
                },
                unsetSimpleProductPackFormData(){

                },
                unsetConfigurableProductPackFormData(){
                    const configurableProductPackEl = document.getElementById('configurable-product-pack-data');
                    if(configurableProductPackEl){
                        configurableProductPackEl.innerHTML = '';
                    }
