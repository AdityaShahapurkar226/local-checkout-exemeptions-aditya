                calculateTotalPrice(itemId){
                    this.updateTotalPrice();
                    const checkboxEl = document.querySelector(`input[name="amrelated_products[${itemId}]"]`);
                    if(checkboxEl){
                        if (checkboxEl.checked) {
                            const productType = checkboxEl.getAttribute('data-product-type');
                            if(productType === 'configurable'){
                                // this.getConfigurableSwatches(itemId);
                            }
                        } else {
                            // If Checkbox is unchecked
                        }
                    }
                },
                addPackToCart(shouldShowCartSidebar = false, isSimpleOnly = true){

                    const addToCartBtnAmasty = document.getElementById('ammostviewed-add-to-cart-form');
                    // addToCartBtnAmasty.submit();return false;
                    if(addToCartBtnAmasty){
                        const formData = new FormData(addToCartBtnAmasty);

                        if(!isSimpleOnly){
                            // Get all input fields inside the parent element with id "simple-product-pack-data"
                            const ignoredFields = document.querySelectorAll('#simple-product-pack-data input');

                            // Filter out the ignored fields from the form data
                            for (const field of ignoredFields) {
                                formData.delete(field.name);
                            }
                        }

                        if(formData){
                            const options = {
                                method: 'POST',
                                body: formData
                            };

                            fetch(BASE_URL + 'ammostviewed/cart/add/', options)
                            .then(response => response.json())
                            .then(data => {
                                if(data.is_add_to_cart){
                                    window.dispatchEvent(new CustomEvent('product-addtocart-success'));
                                    window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                                    if(shouldShowCartSidebar){
                                        this.showConfigurablePackSidebar = false;
                                        this.unsetSimpleProductPackFormData();
                                        window.dispatchEvent(new CustomEvent("toggle-cart"));
                                    }
                                }
                            })
                            .catch(error => {
                                console.error('Error:', error);
                            });
                        }
                    }
                },
                addToCartAlpine(itemId){
                    const itemData = JSON.parse(this.itemConfig);
                    const packList = document.querySelector('.amrelated-pack-list-ahy');
                    if(packList){
                        const checkedInputs = packList.querySelectorAll('input[type="checkbox"]:checked');

                        var hasConfigurable = false;
                        const configurableProductIdArr = [];
                        if(checkedInputs){
                            checkedInputs.forEach((input) => {
                                const productType = input.getAttribute('data-product-type');
                                const productId = input.getAttribute('data-product-id');
                                if(productType === 'configurable'){
                                    hasConfigurable = true;
                                    configurableProductIdArr.push(productId);
                                }
                            });
                        }
                        if(hasConfigurable){
                            this.getConfigurableSwatches(configurableProductIdArr);
                            //Silently Add simple products to cart
                            var shouldShowCartSidebar = false;
                            this.addPackToCart(shouldShowCartSidebar, true);
                        } else {
                            //Add All checked simple products to cart
                            this.addPackToCart(true, true);
                        }
                    }
                },
                getConfigurableSwatches(configurableProductIdArr = []){
                    //ajax call to the controller to fetch swatches
                    //Use this function to get swatches of a configurable product
                    if (configurableProductIdArr.length > 0){
                        this.showConfigurablePackSidebar = true;
                        const parentEl = document.getElementById('configurable-product-data');
                        parentEl.innerHTML = '';
                        configurableProductIdArr.forEach(async (configurableProductId) => {
                            const itemNames = JSON.parse(this.additionalItemDataJson);
                            const productName = itemNames[configurableProductId]['name'];
                            const productImageUrl = itemNames[configurableProductId]['imageUrl'];
                            const productNameHtml = '<h2 class="product-name text-3xl font-bold pb-4">'+productName+'</h2>';
                            console.log(productNameHtml);
                            const productImageHtml = `<img src="${productImageUrl}" alt="${productName}">`;

                            const configurableProductSwatchesEl = document.createElement('div');
                            configurableProductSwatchesEl.setAttribute('data-product-id', configurableProductId);
                            configurableProductSwatchesEl.setAttribute('id', 'configurable-product-swatches' + configurableProductId);

                            const configurableProductNameEl = document.createElement('div');
                            configurableProductNameEl.setAttribute('data-product-id', configurableProductId);
                            configurableProductNameEl.setAttribute('id', 'configurable-product-name' + configurableProductId);

                            const configurableProductPriceEl = document.createElement('div');
                            configurableProductPriceEl.setAttribute('data-product-id', configurableProductId);
                            configurableProductPriceEl.setAttribute('id', 'configurable-product-price' + configurableProductId);

                            const configurableProductGalleryEl = document.createElement('div');
                            configurableProductGalleryEl.setAttribute('data-product-id', configurableProductId);
                            configurableProductGalleryEl.setAttribute('id', 'configurable-product-gallery' + configurableProductId);
                            configurableProductGalleryEl.style.display = 'flex';
                            configurableProductGalleryEl.style.justifyContent = 'center';

                            if (parentEl) {
                                parentEl.appendChild(configurableProductNameEl);
                                parentEl.appendChild(configurableProductGalleryEl);
                                parentEl.appendChild(configurableProductPriceEl);
                                parentEl.appendChild(configurableProductSwatchesEl);
                            } else {
                                console.error('Parent element not found');
                            }
                            try {
                                const response = await fetch(`${BASE_URL}ahy_themecustomization/index/GetProductSwatchesDetails?product_id=` + configurableProductId);
                                const data = await response.json();
                                const parentEl = document.getElementById('configurable-product-data');
                                if (data.success === true) {
                                    const oldScriptElem = document.getElementById('swatchesScriptContentDynamic-' + configurableProductId);
                                    if (!oldScriptElem) {
                                        const scriptElem = document.createElement('script');
                                        scriptElem.type = 'text/javascript';
                                        scriptElem.id = 'swatchesScriptContentDynamic-' + configurableProductId;
                                        scriptElem.innerHTML = data.swatch_script;
                                        document.body.appendChild(scriptElem);
                                    }

                                    const oldPriceScriptElem = document.getElementById('swatchesPriceScript-' + configurableProductId);
                                    if (!oldPriceScriptElem) {
                                        const scriptPriceElem = document.createElement('script');
                                        scriptPriceElem.type = 'text/javascript';
                                        scriptPriceElem.id = 'swatchesPriceScript-' + configurableProductId;
                                        scriptPriceElem.innerHTML = data.product_price_script;
                                        document.body.appendChild(scriptPriceElem);
                                    }

                                    const oldScriptSwatchGalleryElem = document.getElementById('swatchesGalleryScript-' + configurableProductId);
                                    if (!oldScriptSwatchGalleryElem) {
                                        const scriptSwatchGalleryElem = document.createElement('script');
                                        scriptSwatchGalleryElem.type = 'text/javascript';
                                        scriptSwatchGalleryElem.id = 'swatchesGalleryScript-' + configurableProductId;
                                        scriptSwatchGalleryElem.innerHTML = data.product_swatch_gallery_script;
                                        document.body.appendChild(scriptSwatchGalleryElem);
                                    }

                                    const productNameEl = document.getElementById('configurable-product-name' + configurableProductId);
                                    productNameEl.innerHTML = productNameHtml;

                                    const productPriceSwatchEl = document.getElementById('configurable-product-price' + configurableProductId);
                                    productPriceSwatchEl.innerHTML = data.product_price_html;

                                    const swatchHtmlEl = document.getElementById('configurable-product-swatches' + configurableProductId);
                                    swatchHtmlEl.innerHTML = data.swatch_html;

                                    const productSwatchGalleryHtml = document.getElementById('configurable-product-gallery' + configurableProductId);
                                    productSwatchGalleryHtml.innerHTML = productImageHtml;

                                     // append the new div to the parent element
                                    if (parentEl) {
                                        parentEl.appendChild(productNameEl);
                                        parentEl.appendChild(productSwatchGalleryHtml);
                                        parentEl.appendChild(productPriceSwatchEl);
                                        parentEl.appendChild(swatchHtmlEl);
                                    } else {
                                        console.error('Parent element not found');
                                    }

                                } else {
                                    console.log('in else');
                                }

                            } catch (error) {
                                console.error('Error fetching swatches:', error);
                            }
                        });
                    }
                },
                updateTotalPriceWithConfigurableOptions(configurableProductId){

                    console.log('The number of checked Configurable products are ', this.configurableProductCount);
                    console.log('The number of selected configurable products are ', this.swatchItemData.length)

                    this.totalPrice = 0;
                    var simpleProductsPrice = this.basePrice;
                    this.configurableProductPrice = 0;

                    const packList = document.querySelector('.amrelated-pack-list-ahy');
                    const checkedInputs = packList.querySelectorAll('input[type="checkbox"]:checked');
                    if(checkedInputs){
                        checkedInputs.forEach((input) => {
                            const productId = input.getAttribute('data-product-id');
                            const productType = input.getAttribute('data-product-type');
                            if(productType === 'configurable'){
                                //
                            } else if (productType === 'simple'){
                                // If Checkbox is unchecked
                                const itemData = JSON.parse(this.itemConfig);
                                simpleProductsPrice += itemData.products[productId].price;
                            }

                        });
                    }
                    this.totalPrice = simpleProductsPrice;

                    // Code below to calculate price of this configurable product and add to totalprice
                    this.swatchItemData.forEach((item) => {
                        this.configurableProductPrice += item.productOptionPrices.basePrice.amount;
                    });
                    this.totalPrice += this.configurableProductPrice;

                    if(this.configurableProductCount === this.swatchItemData.length){
                        //Enable Add to Cart Button
                        this.enableSideBarAddToCartBtn();
                    }
                },
