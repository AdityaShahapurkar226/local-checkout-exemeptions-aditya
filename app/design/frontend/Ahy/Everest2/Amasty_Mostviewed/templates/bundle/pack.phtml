                watchShowConfigurablePackSidebar(){
                    this.$watch('showConfigurablePackSidebar', (newValue, oldValue) => {
                        if (newValue !== oldValue) {
                            if(newValue === false){
                                // Sidebar Closed
                                this.configurableProductPrice = 0;
                                this.configurableProductCount = 0;
                                this.swatchItemData = [];
