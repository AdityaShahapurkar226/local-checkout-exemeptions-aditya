                updateCheckBoxFromImage(event){
                    const clickedElement = event.target;
                    if(clickedElement){
                        const bundlePackCheckBoxElChecked = clickedElement.parentElement.parentElement.querySelector('.amrelated-checkbox');
                        const isChecked = clickedElement.checked || bundlePackCheckBoxElChecked.checked;
                        if(!isChecked){
                            bundlePackCheckBoxElChecked.checked = true;
                            this.updateTotalPrice(this.itemConfig);
                            this.setSimpleProductPackFormData();
                        } else {
                            bundlePackCheckBoxElChecked.checked = false;
                            this.updateTotalPrice(this.itemConfig);
                            this.setSimpleProductPackFormData();
                        }
                    }
                },
                updateCheckBoxFromDetails(event){
                    const clickedElement = event.target;
                    if(clickedElement){
                        const bundlePackCheckBoxElChecked = clickedElement.parentElement.parentElement.parentElement.querySelector('.amrelated-checkbox');
                        const isChecked = clickedElement.checked || bundlePackCheckBoxElChecked.checked;
                        if(!isChecked){
                            bundlePackCheckBoxElChecked.checked = true;
                            this.updateTotalPrice(this.itemConfig);
                            this.setSimpleProductPackFormData();
                        } else {
                            bundlePackCheckBoxElChecked.checked = false;
                            this.updateTotalPrice(this.itemConfig);
                            this.setSimpleProductPackFormData();
                        }
                    }
                },
                eventListeners: {
                    ['@update-bundle-pack-configurable-selection.window'](event) {
                        const configurableIndex = this.swatchItemData.findIndex(option => option.configurableProductId === event.detail.configurableProductId);

                        if (configurableIndex >= 0) {
                            this.swatchItemData[configurableIndex] = event.detail;
                        } else {
                            this.swatchItemData.push(event.detail);
                        }
                        // console.log('this.swatchItemData in eventListener: ', this.swatchItemData);
                        var configurableProductId = event.detail.configurableProductId;
                        this.updateTotalPriceWithConfigurableOptions(configurableProductId);
                        this.setConfigurableProductPackFormData();
                    }
                },
            }
        }
