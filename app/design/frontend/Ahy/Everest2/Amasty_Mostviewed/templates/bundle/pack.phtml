<script>
        function initBundlePack(){
            return {
                itemConfig: '',
                additionalItemConfig: '',
                totalPrice: 0,
                oldTotalPrice: 0,
                basePrice: 0,
                configurableProductPrice: 0,
                showConfigurablePackSidebar: false,
                swatchItemData: [],
                configurableProductCount: 0,
                currentSlide: 0,
                totalSlides: 0,
                slideWidth: 0,
                infiniteScroll: true,
                itemsPerSlide: 2,
                slides: [],
                currentIndex: 0,
                lastIndex: false,
                isMobile: false,
                init(){
                    this.movePackContainerPosition();
                    this.itemConfig = '<?= $block->encode($config)?>';
                    this.additionalItemDataJson = '<?= $additionalItemDataJson; ?>';
                    this.setSimpleProductPackFormData();
                    this.updateTotalPrice(this.itemConfig);
                    if(this.$refs.slideContainer){
                        this.slides = this.$refs.slideContainer.children;
                        this.$refs.slideContainer.addEventListener('touchstart', this.touchStart.bind(this));
                        this.$refs.slideContainer.addEventListener('touchend', this.touchEnd.bind(this));
                        this.slideWidth = 100/this.itemsPerSlide;
                        this.setSlideWidth(this.slides, this.slideWidth);
                        this.totalSlides = this.slides.length / this.itemsPerSlide;
                    }
                    this.handleResize();
                    window.addEventListener('resize', this.handleResize);
                },
                movePackContainerPosition(){
                    const bundleEl = document.getElementById('ahy-bundle-packs-container');
                    if(bundleEl){
                        const bundleSection = document.querySelector('section.complete-the-situation');
                        if (bundleSection) {
