                                this.disableSidebarAddToCartBtn();
                                this.unsetConfigurableProductPackFormData();
                            } else{
                                // Sidebar Opened
                            }

                        }
                    });
                },
                setSlideWidth(slides, slideWidth) {
                    for (let i = 0; i < slides.length; i++) {
                        slides[i].style.width = slideWidth + '%';
                    }
                },
                next() {
                    if ((this.currentIndex/this.itemsPerSlide) < this.slides.length - this.itemsPerSlide) {
                        this.currentIndex += this.itemsPerSlide;
                        this.updateSlides();
                    } else {

                    }
                },
                prev() {
                    if (this.currentIndex > 0) {
                        this.currentIndex -= this.itemsPerSlide;
                        this.updateSlides();
                    }
                },
                touchStart(event) {
                    this.touchStartX = event.touches[0].clientX;
                },
                touchEnd(event) {
                    const touchEndX = event.changedTouches[0].clientX;
                    const touchDiff = touchEndX - this.touchStartX;
                    if (touchDiff > 0) {
                        this.prev();
                    } else if (touchDiff < 0) {
                        this.next();
                    }
                },
                updateSlides() {
                    const slides = this.slides;
                    const position = -this.currentIndex * this.slideWidth;
                    for (let i = 0; i < slides.length; i++) {
                        slides[i].style.transform = `translateX(${position}%)`;
                        slides[i].style.transition = 'transform 0.5s ease-in-out';
                    }
                    const lastIndexPercentile = 100 * (this.slides.length - this.itemsPerSlide);
                    if(lastIndexPercentile + position === 0){
                        this.lastIndex = true;
                    } else {
                        this.lastIndex = false;
                    }
                },
                disableSidebarAddToCartBtn(){
                    const addToCartBtnEl = document.querySelector('#product-pack-configurable-sidebar #product-addtocart-button');
                    const addToCartSpanEl = document.querySelector('#product-addtocart-button span.add-to');
                    if(addToCartSpanEl){
                        addToCartSpanEl.innerHTML = 'Please Select Options';
                    }
                    if(addToCartBtnEl){
                        addToCartBtnEl.disabled = true;
                    }
                },
                enableSideBarAddToCartBtn(){
                    const addToCartBtnEl = document.querySelector('#product-pack-configurable-sidebar #product-addtocart-button');
                    const addToCartSpanEl = document.querySelector('#product-addtocart-button span.add-to');
                    if(addToCartSpanEl){
                        addToCartSpanEl.innerHTML = 'Add to Cart';
                    }
                    if(addToCartBtnEl){
                        addToCartBtnEl.removeAttribute('disabled');
                        addToCartBtnEl.disabled = false;
                    }
