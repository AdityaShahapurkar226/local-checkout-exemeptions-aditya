                <h2 class="text-xl font-extrabold title-font mb-3 text-primary" role="heading" aria-level="2">
                    <?= $escaper->escapeHtml(__('No account yet?')) ?>
                </h2>
            </div>
            <div class="block-content" aria-labelledby="block-new-customer-heading">
