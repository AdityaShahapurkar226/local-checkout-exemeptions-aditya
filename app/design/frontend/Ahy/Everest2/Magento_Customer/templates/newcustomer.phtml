use Magento\Framework\Escaper;

/** @var Info $block */
/** @var Escaper $escaper */
?>
<?php if ($block->getRegistration()->isAllowed()): ?>
    <div class="flex flex-col w-full md:w-1/2 justify-between">
        <!-- new customer -->
        <div class="block-new-customer card my-8 p-6 md:my-0 bg-ahy-yellow-card">
