                    <?= $escaper->escapeHtml( // phpcs:disable Generic.Files.LineLength.TooLong
                        __('Checkout as a guest. Plus, you can create an account for next time.')
                    ) // phpcs:enable ?>
                </p>
            </div>
            <div class="flex justify-center">
                <a class="block w-full font-bold text-ahy-blue" href="<?= $escaper->escapeUrl($block->getCreateAccountUrl()) ?>">
                    <button class="rounded-full p-2 px-10 hover:shadow-[#0d2f47_0px_0px_0px_1px_inset] border-ahy-blue border-3 text-ahy-blue w-full">
                        <span><?= $escaper->escapeHtml(__('Create an Account')) ?></span>
                    </button>
                </a>
            </div>
        </div>
