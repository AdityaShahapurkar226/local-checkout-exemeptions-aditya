            <a class="block px-0.5 py-1 mt-2 font-bold text-ahy-blue"
                href="<?= $escaper->escapeUrl($block->getUrl('wishlist')) ?>">
                <?= $escaper->escapeHtml(__('My Wish List')); ?>
            </a>
            <a class="block px-0.5 py-1 mt-2 font-bold text-ahy-blue"
                href="<?= $escaper->escapeUrl($block->getUrl('sales/order/history')) ?>">
                <?= $escaper->escapeHtml(__('My Orders')); ?>
            </a>
            <span>
                <hr class="p-px bg-white mt-3">
            </span>
            <a class="block px-4 py-2 lg:px-5 lg:py-2 text-xs justify-center flex mt-3 mb-3 underline underline-offset-8 text-ahy-blue"
