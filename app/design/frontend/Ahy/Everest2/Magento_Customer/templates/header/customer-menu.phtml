                </a>
                <a class="block px-0.5 py-1 mt-2 font-bold text-ahy-blue hover:underline underline-offset-4"
                    href="<?= $escaper->escapeUrl($block->getUrl('sales/order/history')) ?>">
                    <?= $escaper->escapeHtml(__('My Orders')); ?>
                </a>
            <?php endif; ?>
        <?php endif; ?>
    </nav>
</div>