        x-cloak x-show="open"
        aria-labelledby="customer-menu">
        <?php if ($block->customerLoggedIn()): ?>
            <a class="block px-0.5 py-1 mt-2 font-bold text-ahy-blue"
                href="<?= $escaper->escapeUrl($block->getUrl('customer/account')) ?>">
                <?= $escaper->escapeHtml(__('My Account')); ?>
