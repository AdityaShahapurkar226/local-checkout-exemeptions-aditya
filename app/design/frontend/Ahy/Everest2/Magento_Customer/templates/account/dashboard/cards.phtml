$heroicons = $viewModels->require(HeroiconsOutline::class);
/** @var CustomerVaultCards $vaultCards */
$vaultCards = $viewModels->require(CustomerVaultCards::class);

/** @var \Ahy\SavedCC\ViewModel\ConfigProvider $savedCcConfig */
$savedCcConfig = $viewModels->require(\Ahy\SavedCC\ViewModel\ConfigProvider::class);

if (!$savedCcConfig->isEnabled()) {
    return; // do not render anything
}

$tokens = $vaultCards->getAllVisibleCustomerTokens();
$currentYear = (int) date('Y');
$currentMonth = (int) date('m');

$activeTokens = [];
$expiredTokens = [];

/**
 * Normalize card type from raw gateway format to readable and mappable format
 */
function normalizeCardType(string $rawType): string
{
    $map = [
        'VISA' => 'Visa',
        'MASTERCARD' => 'Mastercard',
        'AMEX' => 'American Express',
        'AMERICANEXPRESS' => 'American Express', // Added for no-space variant
        'AMERICAN EXPRESS' => 'American Express',
        'DISCOVER' => 'Discover',
        'JCB' => 'JCB',
        'DINERSCLUB' => 'Diners Club/ Carte Blanche', // No-space variant
        'DINERS CLUB' => 'Diners Club/ Carte Blanche',
        'DINERS CLUB/ CARTE BLANCHE' => 'Diners Club/ Carte Blanche',
    ];

    // Normalize: remove spaces, slashes, make uppercase
    $key = strtoupper(preg_replace('/[^A-Z]/', '', $rawType));
    return $map[$key] ?? 'Unknown';
}
// Short label map
function normalizeCardShortName(string $rawType): string
{
    $map = [
        'VISA' => 'VISA',
        'MASTERCARD' => 'MASTERCARD',
        'AMEX' => 'AMEX',
        'AMERICANEXPRESS' => 'AMEX',
        'AMERICAN EXPRESS' => 'AMEX',
        'DISCOVER' => 'DISCOVER',
        'JCB' => 'JCB',
        'DINERSCLUB' => 'DINERS CLUB',
        'DINERS CLUB' => 'DINERS CLUB',
        'DINERS CLUB/ CARTE BLANCHE' => 'DINERS CLUB',
    ];
    $key = strtoupper(preg_replace('/[^A-Z]/', '', $rawType));
    return $map[$key] ?? $rawType;
}

/**
 * Get logo URL for card type
 */
function getCardLogoUrl(string $cardType): string
{
    $map = [
        'Visa' => '/media/icons/visa.svg',
        'Mastercard' => '/media/icons/mastercard.svg',
        'American Express' => '/media/icons/amex.svg',
        'Discover' => '/media/icons/discover.svg',
        'JCB' => '/media/icons/jcb.svg',
        'Diners Club/ Carte Blanche' => '/media/icons/diners.svg',
        'Unknown' => '/media/icons/unknown-code.svg',
    ];
    return $map[$cardType] ?? $map['Unknown'];
}

foreach ($tokens as $token) {
    $details = $vaultCards->getCardDetails($token);
    $expDate = DateTime::createFromFormat('m/Y', $details['expirationDate'] ?? '00/0000');
    $isExpired = $expDate < new DateTime('first day of this month');

    $entry = [
        'token' => $token,
        'details' => $details,
        'expDate' => $expDate,
    ];

    if ($isExpired) {
        $expiredTokens[] = $entry;
    } else {
        $activeTokens[] = $entry;
    }
}

$sortedTokens = array_merge($activeTokens, $expiredTokens);
?>

