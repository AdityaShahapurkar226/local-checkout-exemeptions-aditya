<script>
    function pdpCartCarousel() {
        return {
            cartItems:   [],
            isLoading:   false,
            atStart:     true,
            atEnd:       false,
            progressPct: 0,

            /* --- drag state --- */
            _dragging:    false,
            _dragStartX:  0,
            _scrollStart: 0,
            _moved:       false,
            _lastX:      0,
            _lastTime:   0,
            _velocity:   0,
            _rafId:      null,

            /* =================== lifecycle =================== */
                init() {
                    const loadFromCache = () => {
                        try {
                            const cache = JSON.parse(localStorage.getItem('mage-cache-storage') || '{}');
                            if (cache && cache.cart && cache.cart.items && cache.cart.items.length > 0) {
                                this.cartItems = this._sorted(cache.cart.items);
                                // this.$nextTick(() => this.onScroll());
                                this.$nextTick(() => { this.onScroll(); this.updateLayout(); });
                                return true;
                            }
                        } catch(e) {}
                        return false;
                    };
                    document.addEventListener('pointerup', (e) => {
                        if (this._dragging) this.dragEnd(e);
                    });

                    if (!loadFromCache()) {
                        setTimeout(() => {
                            loadFromCache();
                        }, 500);
                    }

                    window.addEventListener('reload-customer-section-data', () => {
                            this.isLoading = false;
                        });
                    window.addEventListener('private-content-loaded', (e) => {
                        if (!e.detail || !e.detail.data || !e.detail.data.cart) return;

                        // 1. Merge hover map FIRST
                        window.addEventListener('private-content-loaded', (e) => {
                            if (!e.detail || !e.detail.data || !e.detail.data.cart) return;
                            this.cartItems = this._sorted(e.detail.data.cart.items || []);
                            this.isLoading = false;
                            this.$nextTick(() => { this.onScroll(); this.updateLayout(); });
                        });
                            // 3. cartItems AFTER map is ready
                            this.cartItems = this._sorted(e.detail.data.cart.items || []);
                            this.isLoading = false;
                            this.$nextTick(() => { this.onScroll(); this.updateLayout(); });
                        });

                },  

                onSectionLoad(data) {
                    if (!data || !data.cart) return;

                    this.cartItems = this._sorted(data.cart.items || []);
                    this.$nextTick(() => { this.onScroll(); this.updateLayout(); });
                    console.log('section load done')
                },

            /* =================== helpers =================== */

            _sorted(items) {
                return items
                    .filter(item => parseFloat(item.product_price_value) > 0)
                    .slice()
                    .sort((a, b) => Number(a.item_id) - Number(b.item_id));
            },

            formatPrice(value) {
                if (value === undefined || value === null) return '';
                return '$' + parseFloat(value).toFixed(2);
            },

            getProductImage(item) {
                if (!item.product_image || !item.product_image.src) return '';
                return item.product_image.src
                    .replace(/\/cache\/[a-f0-9]+\//, '/');
            },

            /* =================== stepper =================== */

            updateItemQty(itemId, newQty) {
                if (newQty < 1) {
                    this.deleteItemFromCart(itemId);
                    return;
                }
                this.isLoading = true;
                const formKey = hyva.getFormKey();
                const postUrl = BASE_URL + 'checkout/sidebar/updateItemQty/';
                fetch(postUrl, {
                    headers: {
                        'content-type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    },
                    body: 'form_key=' + formKey + '&item_id=' + itemId + '&item_qty=' + newQty,
                    method: 'POST',
                    mode: 'cors',
                    credentials: 'include'
                }).then(response => {
                    if (response.ok) return response.json();
                    this.isLoading = false;
                }).then(result => {
                        if (result && result.success) {
                            window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                        } else {
                            this.isLoading = false;
                        }
                    });
                                },

            deleteItemFromCart(itemId) {
                this.isLoading = true;
                const formKey = hyva.getFormKey();
                const postUrl = BASE_URL + 'checkout/sidebar/removeItem/';
                fetch(postUrl, {
                    headers: {
                        'content-type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    },
                    body: 'form_key=' + formKey + '&item_id=' + itemId,
                    method: 'POST',
                    mode: 'cors',
                    credentials: 'include'
                }).then(response => {
                    if (response.ok) return response.json();
                    this.isLoading = false;
                }).then(result => {
                    if (result && result.success) {
                        window.dispatchEvent(new CustomEvent('reload-customer-section-data'));
                    } else {
                        this.isLoading = false;
                    }
                });
            },

            /* =================== scroll state =================== */

            onScroll() {
                const t = this.$refs.track;
                if (!t) return;
                const max        = t.scrollWidth - t.clientWidth;
                this.atStart     = t.scrollLeft <= 2;
                this.atEnd       = t.scrollLeft >= max - 2;
                this.progressPct = max > 0 ? Math.round((t.scrollLeft / max) * 100) : 0;
            },

            updateLayout() {
                const t = this.$refs.track;
                if (!t) return;
                const isOverflowing = t.scrollWidth > t.clientWidth;
                t.classList.toggle('is-centered', !isOverflowing);
            },

            scrollBy(direction) {
                const t = this.$refs.track;
                if (!t) return;
                t.scrollLeft += direction * 150;
            },

            /* =================== shift + scroll =================== */

                onWheel(e) {
                    const t = this.$refs.track;
                    if (!t) return;
                    if (e.shiftKey) {
                        e.preventDefault();
                        t.scrollLeft += e.deltaY || e.deltaX;
                    }
                },

            dragStart(e) {
                if (e.button !== 0 && e.pointerType === 'mouse') return;
                if (e.target.closest('button')) return;
                const t = this.$refs.track;
                if (!t) return;

                if (this._rafId) { cancelAnimationFrame(this._rafId); this._rafId = null; }

                this._dragging   = true;
                this._moved      = false;
                this._dragStartX = e.clientX;
                this._lastX      = e.clientX;
                this._lastTime   = performance.now();
                this._velocity   = 0;
                this._scrollStart = t.scrollLeft;


                t.classList.add('is-dragging');
                t.style.scrollBehavior = 'auto';
            },


            dragMove(e) {
                if (!this._dragging) return;
                const t = this.$refs.track;
                if (!t) return;

                const now = performance.now();
                const dt  = now - this._lastTime;
                const dx  = e.clientX - this._dragStartX;

                if (dt > 0) this._velocity = (e.clientX - this._lastX) / dt;

                this._lastX    = e.clientX;
                this._lastTime = now;

                if (Math.abs(dx) > 4) this._moved = true;

                t.scrollLeft = this._scrollStart - dx;
            },



            dragEnd(e) {
                if (!this._dragging) return;
                this._dragging = false;
                const t = this.$refs.track;
                t.classList.remove('is-dragging');
                t.style.scrollBehavior = 'auto';

                if (!this._moved) {
                    t.style.scrollBehavior = 'smooth';
                    return;
                }

                let velocity = this._velocity * 18;

                const glide = () => {
                    if (Math.abs(velocity) < 0.5) {
                        t.style.scrollBehavior = 'smooth';
                        this._moved = false;
                        return;
                    }
                    t.scrollLeft -= velocity;
                    velocity *= 0.88;
                    this._rafId = requestAnimationFrame(glide);
                };

                this._rafId = requestAnimationFrame(glide);
            },


            onCardClick(e) {
                if (this._moved) {
                    e.preventDefault();
                    return;
                }
               
            },
        }
    }
</script>
