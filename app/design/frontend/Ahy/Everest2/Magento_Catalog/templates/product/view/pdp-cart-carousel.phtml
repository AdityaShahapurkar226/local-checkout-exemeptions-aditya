/**
 * PDP Cart Carousel
 * Horizontal scrollable cart items strip.
 * - Appears whenever cart has items (persists on reload)
 * - Drag to scroll (pointer events)
 * - Shift + scroll wheel
 * - Prev / Next arrow buttons
 * - Stepper per card (same logic as cart drawer)
 * - Delete item from carousel removes from cart
 */
declare(strict_types=1);

