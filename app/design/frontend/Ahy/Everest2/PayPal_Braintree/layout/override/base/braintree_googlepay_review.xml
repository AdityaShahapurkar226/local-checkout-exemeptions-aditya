<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Review Order</title>
    </head>
    <update handle="checkout_onepage_review_item_renderers"/>
    <body>
        <referenceBlock name="head.components">
        </referenceBlock>
        <referenceContainer name="page.messages">
        </referenceContainer>
        <referenceContainer name="content">
            <block 
                class="PayPal\Braintree\Block\GooglePay\Checkout\Review"
                name="braintree.googlepay.review"
                template="Ahy_GooglePay::express/review.phtml"
            >
                <block class="Magento\Paypal\Block\Express\Review" name="express.review.shipping.method" as="shipping_method" template="Ahy_GooglePay::express/review/shipping/method.phtml"/>
                <block class="Magento\CheckoutAgreements\Block\Agreements" name="paypal.express.review.details.agreements" as="agreements" template="Magento_CheckoutAgreements::additional_agreements.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
