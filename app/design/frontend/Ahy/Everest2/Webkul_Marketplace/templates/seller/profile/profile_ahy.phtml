                                                if (this.src.endsWith('.webp')) {
                                                    this.onerror = null;
                                                    this.src = this.getAttribute('data-original-src');
                                                } else {
                                                    klevu.dom.helpers.cleanUpProductImage(this);
                                                }
                                            "
                                            class="kuProdImg"
                                            loading="lazy"
