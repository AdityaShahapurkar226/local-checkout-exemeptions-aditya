                <?php else: ?>
                    <div class="field">
                        <label class="label" for="amfaq-name">
                            <?= $block->escapeHtml(__('Your name:')); ?>
                        </label>
                        <div class="control">
                            <input name="name" id="amfaq-name" class="input-text  w-full"
                                   title="<?= $block->escapeHtml(__('Name')); ?>"
                                   type="text">
                        </div>
                    </div>
                <?php endif; ?>

                <?php if ($block->isNotifyUser()): ?>
                <?php if ($block->isGDPREnabled()): ?>
                <div class="field amfaq-hidden flex items-center" x-show="showNameField">
                    <?php else: ?>
                    <div class="field flex items-center">
                        <?php endif; ?>
                        <input type="checkbox"
                               name="notification"
                               id="amfaq-notification"
                               title="<?= $block->escapeHtml(__('Notification')); ?>"
