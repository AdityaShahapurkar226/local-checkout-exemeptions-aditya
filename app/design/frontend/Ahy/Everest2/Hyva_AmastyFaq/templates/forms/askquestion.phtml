<script>
    function initFaqForm() {
        return {
            showFaqForm: false,
            allowRegistered: <?= $block->isAllowUnregisteredCustomersAsk() ? 'true' : 'false' ?>,
            isLoggedIn: <?= $block->isCustomerLoginIn() ? 'true' : 'false' ?>,
            showFormBtnText: "<?= __('Ask a Question') ?>",
            hideFormBtnText: "<?= __('Hide form') ?>",
            showNameField: false,
            showEmailField: false,
            toggleForm: function (e) {
                this.showFaqForm = !this.showFaqForm
                if (e.target.innerText === this.showFormBtnText) {
                    e.target.innerText = this.hideFormBtnText
                } else {
                    e.target.innerText = this.showFormBtnText
                }
            }
        }
    }
</script>
