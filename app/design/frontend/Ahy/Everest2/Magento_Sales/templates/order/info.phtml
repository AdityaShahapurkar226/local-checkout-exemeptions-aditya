/**
 * @var \Magento\Sales\Block\Order\Info $block
 * @var \Magento\Framework\Escaper $escaper
 */
/** @var \Ahy\EfflApiIntegration\ViewModel\OrderFfl $fflViewModel */

$order = $block->getOrder();
$fflViewModel = $block->getViewModel();

$hasFfl = false;
$hasNonFfl = false;

// Loop items and decide FFL status (skip free gifts)
foreach ($order->getAllItems() as $item) {
    $sku = $item->getSku();
    $price = (float)$item->getPrice();

    // Skip free gift logic: price = 0 or SKU starts with "FREE"
    if ($price <= 0 || stripos($sku, 'FREE') === 0) {
        continue;
    }

    if ($fflViewModel->isFflProduct($item)) {
        $hasFfl = true;
    } else {
        $hasNonFfl = true;
    }
}

$fflDealer = $order->getData('ffl_dealer'); // dealer address saved at order level

?>
<?php $order = $block->getOrder() ?>
<div class="mb-4 pb-4 border-b border-container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-2">
        <div class="w-full py-4">
            <p class="font-semibold mb-2"><?= $escaper->escapeHtml(__('Billing Address')) ?></p>
            <div class="box-content">
                <address><?= /* @noEscape */ $block->getFormattedAddress($order->getBillingAddress()) ?></address>
            </div>
        </div>
        <?php if (!$order->getIsVirtual()): ?>
            <div class="w-full py-4">
                <div class="box-content">
                    <?php if ($hasFfl && !$hasNonFfl): ?>
                        <p class="font-semibold"><?= $escaper->escapeHtml(__('FFL Dealer Address')) ?></p>
                        <address><?= $escaper->escapeHtml($fflDealer) ?></address>

                    <?php elseif ($hasFfl && $hasNonFfl): ?>
                        <p class="font-semibold"><?= $escaper->escapeHtml(__('Customer Shipping Address')) ?></p>
                        <address><?= /* @noEscape */ $block->getFormattedAddress($order->getShippingAddress()) ?></address>

                        <p class="font-semibold mt-2"><?= $escaper->escapeHtml(__('FFL Dealer Address')) ?></p>
                        <address><?= $escaper->escapeHtml($fflDealer) ?></address>

                    <?php else: ?>
                        <p class="font-semibold"><?= $escaper->escapeHtml(__('Customer Shipping Address')) ?></p>
                        <address><?= /* @noEscape */ $block->getFormattedAddress($order->getShippingAddress()) ?></address>
                    <?php endif; ?>
                </div>
            </div>
            <div class="w-full py-4">
                <p class="font-semibold mb-2"><?= $escaper->escapeHtml(__('Shipping Method')) ?></p>
                <div class="box-content">
                    <?php if ($order->getShippingDescription()): ?>
                        <?= $escaper->escapeHtml($order->getShippingDescription()) ?>
                    <?php else: ?>
                        <?= $escaper->escapeHtml(__('No shipping information available')) ?>
                    <?php endif; ?>
                </div>
            </div>
        <?php endif; ?>
        <div class="w-full py-4">
            <p class="font-semibold mb-2"><?= $escaper->escapeHtml(__('Payment Method')) ?></p>
            <div class="box-content">
                <?= $block->getPaymentInfoHtml() ?>
            </div>
        </div>
    </div>
</div>